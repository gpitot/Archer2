set SH[TH[d]+R3V]=0
endif
set PH[QH[d]+R3V]=0
else
call DisplayTimedTextToPlayer(GetTriggerPlayer(),.0,.0,WQ[GetPlayerId(GetTriggerPlayer())],"|cffffcc00Inventory is full|r")
endif
else
call DisplayTimedTextToPlayer(GetTriggerPlayer(),.0,.0,WQ[GetPlayerId(GetTriggerPlayer())],"|cffffcc00Invalid Item|r")
endif
endif
set b=false
set ti=null
endfunction
function R8V takes nothing returns boolean
return SubString(GetEventPlayerChatString(),0,$A)=="-retrieve " and((S2I(SubString(GetEventPlayerChatString(),$A,$E))>=1 and S2I(SubString(GetEventPlayerChatString(),$A,$E))<=$C)or(SubString(GetEventPlayerChatString(),$A,$E)=="all" or SubString(GetEventPlayerChatString(),$A,$E)=="a"))
endfunction
function R9V takes nothing returns nothing
local integer d=IT[GetPlayerId(GetTriggerPlayer())]
local string ss=SubString(GetEventPlayerChatString(),3,7)
local integer R3V
local integer a
local integer z
local integer i=0
local integer c=0
local item ti=null
local boolean b=false
if ss=="a" or ss=="all" then
loop
exitwhen i==$C
set c=0
set b=false
set z=PH[QH[d]+i]
if z!=0 then
loop
exitwhen c==6 or b
if UnitItemInSlot(NS[GetPlayerId(GetTriggerPlayer())],c)==null then
set ti=UnitAddItemById(NS[GetPlayerId(GetTriggerPlayer())],PH[QH[d]+i])
if SH[TH[d]+i]>0 then
call SetItemCharges(ti,SH[TH[d]+i])
set SH[TH[d]+i]=0
endif
set PH[QH[d]+i]=0
set b=true
endif
set c=c+1
endloop
endif
set i=i+1
endloop
else
set R3V=S2I(SubString(GetEventPlayerChatString(),3,5))-1
set a=PH[QH[d]+R3V]
if a!=0 then
loop
exitwhen b or i==6
if UnitItemInSlot(NS[GetPlayerId(GetTriggerPlayer())],i)==null then
set b=true
endif
set i=i+1
endloop
if b then
call DisplayTimedTextToPlayer(GetTriggerPlayer(),.0,.0,WQ[GetPlayerId(GetTriggerPlayer())],"|cffffcc00Item Retrieved|r")
set ti=UnitAddItemById(NS[GetPlayerId(GetTriggerPlayer())],a)
if SH[TH[d]+R3V]>0 then
call SetItemCharges(ti,SH[TH[d]+R3V])
set SH[TH[d]+R3V]=0
endif
set PH[QH[d]+R3V]=0
else
call DisplayTimedTextToPlayer(GetTriggerPlayer(),.0,.0,WQ[GetPlayerId(GetTriggerPlayer())],"|cffffcc00Inventory is full|r")
endif
else
call DisplayTimedTextToPlayer(GetTriggerPlayer(),.0,.0,WQ[GetPlayerId(GetTriggerPlayer())],"|cffffcc00Invalid Item|r")
endif
endif
set b=false
set ti=null
endfunction
function IVV takes nothing returns boolean
return SubString(GetEventPlayerChatString(),0,3)=="-r " and((S2I(SubString(GetEventPlayerChatString(),3,7))>=1 and S2I(SubString(GetEventPlayerChatString(),3,7))<=$C)or(SubString(GetEventPlayerChatString(),3,7)=="all" or SubString(GetEventPlayerChatString(),3,7)=="a"))
endfunction
function IEV takes nothing returns nothing
local integer d=IT[GetPlayerId(GetTriggerPlayer())]
local integer i=0
local string s
local integer a
local item ti
if GetLocalPlayer()==GetTriggerPlayer()then
call DisplayTextToPlayer(GetTriggerPlayer(),.0,.0,"|cffffcc00Your Vault|r")
endif
loop
exitwhen i==$C
set a=PH[QH[d]+i]
if a==0 then
set s="|cffffcc00Slot "+I2S(i+1)+": No Item|r"
else
set ti=CreateItem(a,0,0)
set s="|cffffcc00Slot "+I2S(i+1)+": "+GetItemName(ti)+"|r"
call RemoveItem(ti)
endif
call DisplayTimedTextToPlayer(GetTriggerPlayer(),.0,.0,WQ[GetPlayerId(GetTriggerPlayer())],s)
set i=i+1
endloop
call DisplayTimedTextToPlayer(GetTriggerPlayer(),.0,.0,WQ[GetPlayerId(GetTriggerPlayer())],"|cffffcc00To store, type '-store (inventory number)'|r")
call DisplayTimedTextToPlayer(GetTriggerPlayer(),.0,.0,WQ[GetPlayerId(GetTriggerPlayer())],"|cffffcc00To retrieve, type '-retrieve (inventory number)'|r")
set s=null
set ti=null
endfunction
