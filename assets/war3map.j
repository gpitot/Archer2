set N0V=true
endif
set i=i-1
endloop
if N0V==false then
call NLV(QJ[SJ[d]+MJ[d]])
call GroupRemoveUnit(JJ[d],QJ[SJ[d]+MJ[d]])
set QJ[SJ[d]+4]=QJ[SJ[d]+3]
set QJ[SJ[d]+3]=QJ[SJ[d]+2]
set QJ[SJ[d]+2]=QJ[SJ[d]+1]
set QJ[SJ[d]+1]=QJ[SJ[d]]
set QJ[SJ[d]]=R1
call GroupAddUnit(JJ[d],R1)
endif
endif
endif
call GroupRemoveUnit(g,R1)
endloop
set R1=null
call F1(g)
set g=null
set u=null
