set NQV=Deg2Rad(GetUnitFacing(R1))
if Q1(x,y,tx,ty)>=100. and Q1(x,y,tx,ty)<=500. then
set NTV=U1(NSV-1.57)
set NUV=U1(NSV+1.57)
if(W1(NQV,NTV,.8) or W1(NQV,NUV,.8))and NKV(R1) then
set f=K7(R1)
set e=NFV(NS[GetPlayerId(GetOwningPlayer(R1))])
set MD[f]=1410065407.
set RF[f]=true
set CF[f]=true
set AF[f]=true
set GD[f]=u
if e!=0 then
call GroupRemoveUnit(JJ[e],R1)
else
set PD[f]=PD[f]/ 2.
endif
call SetUnitOwner(R1,GetOwningPlayer(u),true)
set i=MJ[d]
set i2=0
loop
exitwhen i==-1
if QJ[SJ[d]+i]==null then
set i2=i-1
loop
exitwhen i2==-1 or QJ[SJ[d]+i]!=null
if QJ[SJ[d]+i2]!=null then
