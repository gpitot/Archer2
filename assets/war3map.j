loop
set tu=FirstOfGroup(g2)
exitwhen tu==null
set e=K7(tu)
if GetUnitState(u,UNIT_STATE_MANA)>=PD[e]/ 200. then
call SetUnitState(u,UNIT_STATE_MANA,GetUnitState(u,UNIT_STATE_MANA)-PD[e]/ 200.)
set x=GetUnitX(tu)
set y=GetUnitY(tu)
set J8=MD[e]-LD[e]
set tx=I2(x,J8,Deg2Rad(GetUnitFacing(tu)))
set ty=N2(y,J8,Deg2Rad(GetUnitFacing(tu)))
set A5V=P1(x,y,tx,ty)
set A6V=I2(tx,350.,(A5V+.7))
set A7V=N2(ty,350.,(A5V+.7))
set A8V=I2(tx,350.,(A5V-.7))
set A9V=N2(ty,350.,(A5V-.7))
set B6V=PD[e]*(.3333+(i*.0166))
call U7(GetUnitTypeId(tu),u,i,x,y,tx,ty,.03,UD[e],KD[e],ZD[e],FF[e],J8,B6V,tu,null)
call U7(GetUnitTypeId(tu),u,i,x,y,A6V,A7V,.03,UD[e],KD[e],ZD[e],FF[e],J8,B6V,tu,null)
call U7(GetUnitTypeId(tu),u,i,x,y,A8V,A9V,.03,UD[e],KD[e],ZD[e],FF[e],J8,B6V,tu,null)
set e=0
call GroupRemoveUnit(g2,tu)
call RemoveUnit(tu)
else
call GroupRemoveUnit(g2,tu)
endif
endloop
else
call F2(GetOwningPlayer(u),"No arrows")
call UnitRemoveAbility(u,'A023')
call UnitAddAbility(u,'A023')
call SetUnitAbilityLevel(u,'A023',i)
endif
set u=null
set tu=null
call F1(g2)
