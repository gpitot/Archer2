if Y2(WP[i])>0 and WP[i]!=null then
set PC=PC+1
set OKV=i
endif
set i=i+1
endloop
if PR==$C then
if PC==2 and DM==false and RM==false then
set s=ES[GetPlayerId(GetOwningPlayer(GetTriggerUnit()))]+XS[GetPlayerId(GetOwningPlayer(GetTriggerUnit()))]+"|r has placed |cffffcc003rd|r + "+I2S(MR*$A/ 3)+" kills|r"
call DisplayTimedTextFromPlayer(GetLocalPlayer(),.0,.0,999999.,s)
set AQ[GetPlayerId(GetOwningPlayer(GetTriggerUnit()))]=AQ[GetPlayerId(GetOwningPlayer(GetTriggerUnit()))]+(MR*$A/ 3)
set HQ[GetPlayerId(GetOwningPlayer(GetTriggerUnit()))]=HQ[GetPlayerId(GetOwningPlayer(GetTriggerUnit()))]+(MR*$A/ 3)
call E5(GetOwningPlayer(GetTriggerUnit()))
call O5(GetOwningPlayer(GetTriggerUnit()))
call R5(GetOwningPlayer(GetTriggerUnit()))
elseif PC==1 and DM==false and RM==false then
set AQ[GetPlayerId(GetOwningPlayer(GetTriggerUnit()))]=AQ[GetPlayerId(GetOwningPlayer(GetTriggerUnit()))]+(MR*$A/ 2)
set HQ[GetPlayerId(GetOwningPlayer(GetTriggerUnit()))]=HQ[GetPlayerId(GetOwningPlayer(GetTriggerUnit()))]+(MR*$A/ 2)
set s=ES[GetPlayerId(GetOwningPlayer(GetTriggerUnit()))]+XS[GetPlayerId(GetOwningPlayer(GetTriggerUnit()))]+"|r has placed |cffffcc002nd|r + "+I2S(MR*$A/ 2)+" kills|r"
call DisplayTimedTextFromPlayer(GetLocalPlayer(),.0,.0,999999.,s)
set p2=F3(WP[OKV])
set AQ[GetPlayerId(p2)]=AQ[GetPlayerId(p2)]+(MR*$A)
set HQ[GetPlayerId(p2)]=HQ[GetPlayerId(p2)]+(MR*$A)
set s=ES[GetPlayerId(p2)]+XS[GetPlayerId(p2)]+"|r has placed |cffffcc001st|r + "+I2S(MR*$A)+" kills|r"
call DisplayTimedTextFromPlayer(GetLocalPlayer(),.0,.0,999999.,s)
set s=ES[GetPlayerId(p2)]+GetPlayerName(p2)+"|r is Victorious!"
call DisplayTimedTextFromPlayer(GetLocalPlayer(),.0,.0,999999.,s)
call DisplayTimedTextFromPlayer(GetLocalPlayer(),.0,.0,999999.,"|cffffcc00Do not forget to save your stats by typing -save!|r")
set g=D1()
call GroupEnumUnitsInRect(g,bj_mapInitialPlayableArea,null)
call ForGroup(g,function ODV)
call F1(g)
set g=null
set FR=true
elseif PC==1 and(DM or RM)then
set p2=F3(WP[OKV])
set AQ[GetPlayerId(p2)]=AQ[GetPlayerId(p2)]+(MR*$A)
set HQ[GetPlayerId(p2)]=HQ[GetPlayerId(p2)]+(MR*$A)
