function J7 takes nothing returns boolean
local integer d=T3()
local real cx=I2(GetUnitX(HD[d]),98,U1(Deg2Rad(GetUnitFacing(HD[d]))+3.1415))
local real cy=N2(GetUnitY(HD[d]),98,U1(Deg2Rad(GetUnitFacing(HD[d]))+3.1415))
local real tx=I2(GetUnitX(HD[d]),'d',Deg2Rad(GetUnitFacing(HD[d])))
local real ty=N2(GetUnitY(HD[d]),'d',Deg2Rad(GetUnitFacing(HD[d])))
if GetUnitState(HD[d],UNIT_STATE_LIFE)>.405 then
call R0('h00K',GD[d],JD[d],cx,cy,tx,ty,.03,150.,33.,33.,.3,99999999.,PD[d]/ 2.,null,HD[d])
endif
