call S5(GetTriggerUnit(),.01)
call SetPlayerAbilityAvailable(GetOwningPlayer(GetTriggerUnit()),'A00U',false)
call SetPlayerAbilityAvailable(GetOwningPlayer(GetTriggerUnit()),'A00S',true)
call SetUnitAbilityLevel(GetTriggerUnit(),'A00S',1)
call O4(function C1V,d,.03)
