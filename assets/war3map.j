elseif HS[9] and JS[9]==false then
set JS[9]=true
set b=b+"|c00FF0000/Round Mode "+I2S(SR)+"|r"
elseif JS[9] then
set b=b+"|c00FF0000/Round Mode "+I2S(SR)+"|r"
endif
if HS[$A] and JS[$A] then
