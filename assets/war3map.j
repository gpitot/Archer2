set SC[d]=AddSpecialEffectTarget("Abilities\\Spells\\Human\\MassTeleport\\MassTeleportTo.mdl",D5,"origin")
call O4(function Z6,d,C2)
endfunction
function X7 takes integer LY returns nothing
set ED[LY]=null
endfunction
function O7 takes integer LY returns nothing
if LY==null then
call DisplayTimedTextToPlayer(GetLocalPlayer(),0,0,1000.,"Attempt to destroy a null struct of type: UFS")
return
elseif(VD[LY]!=-1)then
call DisplayTimedTextToPlayer(GetLocalPlayer(),0,0,1000.,"Double free of type: UFS")
return
endif
call X7(LY)
set VD[LY]=YC
set YC=LY
endfunction
function R7 takes nothing returns boolean
local integer d=T3()
set OD[d]=OD[d]-XD[d]
if OD[d]<=RD[d]then
set OD[d]=0
if ID[d]!=-1 then
if GetLocalPlayer()!=Player(ID[d])then
call SetUnitVertexColor(ED[d],$FF,$FF,$FF,R2I(RD[d]))
endif
else
call SetUnitVertexColor(ED[d],$FF,$FF,$FF,R2I(RD[d]))
endif
call O7(d)
return true
endif
if OD[d]<0 then
set OD[d]=0
if ID[d]!=-1 then
if GetLocalPlayer()!=Player(ID[d])then
call SetUnitVertexColor(ED[d],$FF,$FF,$FF,0)
endif
else
call SetUnitVertexColor(ED[d],$FF,$FF,$FF,0)
endif
call O7(d)
return true
endif
if ID[d]!=-1 then
if GetLocalPlayer()!=Player(ID[d])then
call SetUnitVertexColor(ED[d],$FF,$FF,$FF,R2I(OD[d]))
endif
else
call SetUnitVertexColor(ED[d],$FF,$FF,$FF,R2I(OD[d]))
endif
return false
endfunction
function I7 takes nothing returns boolean
local integer d=T3()
set OD[d]=OD[d]+XD[d]
if OD[d]>=RD[d]then
set OD[d]=0
if ID[d]!=-1 then
if GetLocalPlayer()!=Player(ID[d])then
call SetUnitVertexColor(ED[d],$FF,$FF,$FF,R2I(RD[d]))
endif
else
call SetUnitVertexColor(ED[d],$FF,$FF,$FF,R2I(RD[d]))
endif
call O7(d)
return true
endif
if OD[d]>$FF then
set OD[d]=0
call O7(d)
return true
endif
if ID[d]!=-1 then
if GetLocalPlayer()!=Player(ID[d])then
call SetUnitVertexColor(ED[d],$FF,$FF,$FF,R2I(OD[d]))
endif
else
call SetUnitVertexColor(ED[d],$FF,$FF,$FF,R2I(OD[d]))
endif
return false
endfunction
function A7 takes unit u,real A0,real C2,real ct,real ft,integer N7 returns nothing
local integer d=M0()
if ct==ft then
return
endif
if C2<.03 then
if N7!=-1 then
if GetLocalPlayer()!=Player(N7)then
call SetUnitVertexColor(ED[d],$FF,$FF,$FF,R2I(ft))
endif
else
call SetUnitVertexColor(ED[d],$FF,$FF,$FF,R2I(ft))
endif
return
endif
set ED[d]=u
set OD[d]=ct
set ID[d]=N7
set RD[d]=ft
if ct>ft then
set XD[d]=(ct-ft)/(C2/ A0)
call O4(function R7,d,A0)
else
set XD[d]=(ft-ct)/(C2/ A0)
call O4(function I7,d,A0)
endif
endfunction
function B7 takes player p,integer i returns nothing
local unit R1
local integer d
loop
set R1=FirstOfGroup(YP[GetPlayerId(p)])
exitwhen R1==null
set d=V0(R1)
if d!=0 then
if PF[d]<=i and GetUnitAbilityLevel(R1,'A02B')==0 then
call UnitAddAbility(R1,'A02B')
call UnitRemoveAbility(R1,'A02G')
call UnitRemoveAbility(R1,'A02H')
call UnitRemoveAbility(R1,'A02I')
call UnitRemoveAbility(R1,'A02J')
call UnitRemoveAbility(R1,'A00K')
call UnitRemoveAbility(R1,'A02K')
call SetUnitVertexColor(R1,$FF,$FF,$FF,$FF)
endif
call GroupRemoveUnit(YP[GetPlayerId(p)],R1)
endif
endloop
endfunction
