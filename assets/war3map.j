set i=MJ[d]
set N0V=false
loop
exitwhen i==-1 or N0V
if IsUnitInGroup(QJ[SJ[d]+i],JJ[d])==false then
if QJ[SJ[d]+i]!=null and GetUnitState(QJ[SJ[d]+i],UNIT_STATE_LIFE)>.405 then
call NLV(QJ[SJ[d]+i])
endif
set QJ[SJ[d]+i]=R1
