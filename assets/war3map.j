function EGV takes nothing returns nothing
local integer i=0
local integer B6=0
call SetRandomSeed(GetRandomInt(1,$F4240))
if WI==1 then
loop
exitwhen i==$C
set CS[i]=QQ[i]
set DS[i]=SQ[i]
set i=i+1
endloop
elseif WI==2 then
loop
exitwhen i==$C
set CS[i]=TQ[i]
set DS[i]=UQ[i]
set i=i+1
endloop
endif
set i=0
set QI=$B
loop
exitwhen i==$C
set B6=GetRandomInt(0,QI)
set FS[i]=CS[B6]
set GS[i]=DS[B6]
set CS[B6]=CS[QI]
set DS[B6]=DS[QI]
set QI=QI-1
set i=i+1
endloop
endfunction
function EHV takes nothing returns boolean
return GetUnitTypeId(GetConstructingStructure())=='e00A'
endfunction
function EJV takes nothing returns nothing
local real x
local real y
local unit u=GetConstructingStructure()
local integer i = 0
local player p = GetOwningPlayer(u)
local player neutral = Player(PLAYER_NEUTRAL_PASSIVE)
set x=GetUnitX(u)
set y=GetUnitY(u)
set i = FindOwner(x, y)
call SetUnitOwner(u, neutral, true)
set TreeXs[GetPlayerId(p)] = x
set TreeYs[GetPlayerId(p)] = y
set IS[GetPlayerId(p)]=u
set BS[GetPlayerId(p)]=CreateUnit(p,'h007',x,y,0)
call EnableTrigger(JI)
if GetLocalPlayer()==p then
call PanCameraTo(x,y)
endif
set u=null
endfunction
function EKV takes nothing returns boolean
return GetUnitTypeId(GetTriggerUnit())=='e00A'
endfunction
function ELV takes nothing returns boolean
return GetOwningPlayer(GetFilterUnit())==GetOwningPlayer(SI)and GetUnitPointValue(GetFilterUnit())=='d' and GetUnitAbilityLevel(GetFilterUnit(),'A02B')==1
endfunction
function EMV takes nothing returns boolean
return GetOwningPlayer(GetFilterUnit())==GetOwningPlayer(SI)and GetUnitPointValue(GetFilterUnit())=='d'
endfunction
function EPV takes nothing returns nothing
local integer d
local integer e
local unit u=GetTriggerUnit()
local unit EQV
local player p=Player(FindOwner(GetUnitX(u), GetUnitY(u)))
local group g
local unit R1
local integer c=0
local integer i=1
local integer r=0
local integer z=0
local real x
local real y
local multiboarditem X5=null
local string s

call msgDebug("The owner is:" + I2S(GetPlayerId(p)))
//call SetUnitOwner(u, p, true)
set x=GetUnitX(u)
set y=GetUnitY(u)
call SetUnitX(u,3613.)
call SetUnitY(u,358.)
call RemoveUnit(u)
set EQV=CreateUnit(p,'eaom',x,y,$FA)
call SetUnitPathing(EQV,false)
call ShowUnit(EQV,false)
call SetUnitX(EQV,x)
call SetUnitY(EQV,y)
call ShowUnit(EQV,true)
call SetUnitPathing(EQV,true)
set IS[GetPlayerId(p)]=EQV
set u=EQV
if RM then
call UnitRemoveAbility(EQV,'Aro1')
endif
set SI=u
call SetRandomSeed(QR)
call SetUnitInvulnerable(u,true)
 
call SetPlayerAlliance(p,p,ALLIANCE_PASSIVE,true)
call SetPlayerAlliance(p,p,ALLIANCE_HELP_REQUEST,true)
call SetPlayerAlliance(p,p,ALLIANCE_HELP_RESPONSE,true)
call SetPlayerAlliance(p,p,ALLIANCE_SHARED_XP,true)
call SetPlayerAlliance(p,p,ALLIANCE_SHARED_SPELLS,true)
call SetPlayerAlliance(p,p,ALLIANCE_SHARED_CONTROL,true)
call SetPlayerAlliance(p,p,ALLIANCE_SHARED_VISION,true)
call SetPlayerAlliance(p,p,ALLIANCE_SHARED_ADVANCED_CONTROL,true)
 
if NS[GetPlayerId(p)]==null then
set g=D1()
call GroupEnumUnitsInRect(g,bj_mapInitialPlayableArea,Condition(function ELV))
set NS[GetPlayerId(p)]=GroupPickRandomUnit(g)
call F1(g)
set g=null
set e=EBV(NS[GetPlayerId(p)])
set OS[GetPlayerId(p)]=QF[e]
call GroupAddUnit(HR,QF[e])
call EnableTrigger(MA)
set X5=MultiboardGetItem(LQ[GetPlayerId(p)],2,1)
call MultiboardSetItemValue(X5,GetUnitName(NS[GetPlayerId(p)]))
call MultiboardReleaseItem(X5)
set X5=null
set s=ES[GetPlayerId(p)]+XS[GetPlayerId(p)]+"|r has randomed |cffffcc00"+GetUnitName(NS[GetPlayerId(p)])+"|r"
call DisplayTimedTextToPlayer(GetLocalPlayer(),0,0,WQ[GetPlayerId(GetLocalPlayer())],s)
set g=D1()
call GroupEnumUnitsInRect(g,bj_mapInitialPlayableArea,Condition(function EMV))
loop
set R1=FirstOfGroup(g)
if R1==NS[GetPlayerId(p)]then
call GroupRemoveUnit(g,R1)
set R1=FirstOfGroup(g)
endif
exitwhen R1==null
call V7(R1,4)
call GroupRemoveUnit(g,R1)
endloop
call F1(g)
set g=null
endif
call UnitAddAbility(NS[GetPlayerId(p)],'AHds')
call UnitAddAbility(NS[GetPlayerId(p)],'A00H')
call UnitRemoveAbility(NS[GetPlayerId(p)],'A02B')
call SetPlayerAbilityAvailable(p,'AHds',false)
call UnitModifySkillPoints(NS[GetPlayerId(p)],1)
if GetUnitTypeId(NS[GetPlayerId(p)])=='E008' then
set AS[GetPlayerId(p)]=CreateUnit(p,'e009',.0,.0,.0)
set d=WY()
set FP[d]=NS[GetPlayerId(p)]
set DP[d]=AS[GetPlayerId(p)]
call ShowUnit(DP[d],false)
call SY(DP[d],d)
endif
call EnableTrigger(LI)
call EnableTrigger(CI)
call DisableTrigger(DI)
if GetLocalPlayer()==GetOwningPlayer(u)then
call DisplayTimedTextToPlayer(GetLocalPlayer(),.0,.0,WQ[GetPlayerId(GetLocalPlayer())],"|cffffcc00Loading is now disabled|r")
endif
set s=null
if RM then
call SetUnitState(EQV,UNIT_STATE_MANA,GetUnitState(EQV,UNIT_STATE_MAX_MANA))
if TI then
call HY(1)
set TI=false
endif
endif
endfunction
function ESV takes nothing returns boolean
return GetSpellAbilityId()=='A02B'
endfunction
function ETV takes nothing returns boolean
return GetOwningPlayer(GetFilterUnit())==GetOwningPlayer(UI)and GetUnitPointValue(GetFilterUnit())=='d'
endfunction
function EUV takes nothing returns nothing
local unit u=GetTriggerUnit()
local integer d
local player p=GetOwningPlayer(u)
local group g
local unit R1
local string s
local multiboarditem X5=null
set UI=u
set NS[GetPlayerId(p)]=u
set d=EBV(u)
set OS[GetPlayerId(p)]=QF[d]
call GroupAddUnit(HR,QF[d])
call EnableTrigger(MA)
set X5=MultiboardGetItem(LQ[GetPlayerId(p)],2,1)
call MultiboardSetItemValue(X5,GetUnitName(NS[GetPlayerId(p)]))
call MultiboardReleaseItem(X5)
set X5=null
set s=ES[GetPlayerId(p)]+XS[GetPlayerId(p)]+"|r has chosen |cffffcc00"+GetUnitName(u)+"|r"
call DisplayTimedTextFromPlayer(GetLocalPlayer(),.0,.0,WQ[GetPlayerId(GetLocalPlayer())],s)
call UnitRemoveAbility(NS[GetPlayerId(p)],'A02B')
set g=D1()
call GroupEnumUnitsInRect(g,bj_mapInitialPlayableArea,Condition(function ETV))
loop
set R1=FirstOfGroup(g)
if R1==NS[GetPlayerId(p)]then
call GroupRemoveUnit(g,R1)
set R1=FirstOfGroup(g)
endif
exitwhen R1==null
call V7(R1,4)
call GroupRemoveUnit(g,R1)
endloop
call F1(g)
set g=null
set s=null
endfunction
function EWV takes nothing returns nothing
call DisplayTimedTextFromPlayer(GetLocalPlayer(),.0,.0,10.,"|c00ff0000Archer Wars: Legacy 1.4d by cleeezzz|r")
call DisplayTimedTextFromPlayer(GetLocalPlayer(),.0,.0,10.,"|cffffcc00Visit the official forums at|r |c00ff0000ArcherWars.co.cc|r")
call DisplayTimedTextFromPlayer(GetLocalPlayer(),.0,.0,10.,"|cffffcc00While host selects game mode, prepare your load code|r")
if GetLocalPlayer()!=Player(0)then
call SetCineFilterTexture("Fade.blp")
call SetCineFilterBlendMode(BLEND_MODE_BLEND)
call SetCineFilterTexMapFlags(TEXMAP_FLAG_NONE)
call SetCineFilterStartUV(0,0,1,1)
call SetCineFilterEndUV(0,0,1,1)
call SetCineFilterStartColor($FF,$FF,$FF,$FF)
call SetCineFilterEndColor($FF,$FF,$FF,$FF)
call SetCineFilterDuration(.0)
call DisplayCineFilter(true)
endif
endfunction
function EYV takes nothing returns nothing
set TC=CreateUnit(Player(0),'h008',5000.,200.,180.)
call SetCameraBoundsToRect(NO)
set WI=1
if GetLocalPlayer()==Player(0)then
call SelectUnit(TC,true)
call CameraSetupApplyForceDurationWithZ(FO,15000.,0)
call ClearTextMessages()
endif
call DisplayTimedTextToPlayer(GetLocalPlayer(),.0,.0,10.,"|cffffcc00Terrain by Devrak|r")
call DisplayTimedTextToPlayer(GetLocalPlayer(),.0,.0,10.,"|cffffcc00Size: 7045 x 1122|r")
endfunction
