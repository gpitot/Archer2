return((IsUnitEnemy(GetFilterUnit(),GetOwningPlayer(MX)))and(GetWidgetLife(GetFilterUnit())>.405)and(IsUnitType(GetFilterUnit(),UNIT_TYPE_HERO)))!=null
endfunction
function F7 takes nothing returns boolean
return(IsUnitEnemy(GetFilterUnit(),GetOwningPlayer(MX))and GetWidgetLife(GetFilterUnit())>.405 and IsUnitType(GetFilterUnit(),UNIT_TYPE_STRUCTURE)and GetUnitAbilityLevel(GetFilterUnit(),'Avul')==0)!=null
endfunction
