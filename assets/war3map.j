function Z6 takes nothing returns boolean
local integer d=T3()
local integer b=S6(WC[d])
local real x=I2(GetUnitX(WC[d]),200.,4.71)
local real y=N2(GetUnitY(WC[d]),200.,4.71)
call DestroyEffect(AddSpecialEffect("Abilities\\Spells\\Human\\MassTeleport\\MassTeleportCaster.mdl",GetUnitX(UC[d]),GetUnitY(UC[d])))
call SetUnitX(UC[d],H1(x))
call SetUnitY(UC[d],K1(y))
if GetLocalPlayer()==GetOwningPlayer(UC[d])then
call PanCameraTo(x,y)
