function CUV takes nothing returns nothing
local integer a=GetUnitAbilityLevel(GetTriggerUnit(),'A02F')
local real x
local real y
local unit CWV
local unit u
local integer d
set u=GetTriggerUnit()
set CWV=AS[GetPlayerId(GetOwningPlayer(u))]
if GetUnitState(CWV,UNIT_STATE_LIFE)>.405 and IsUnitHidden(CWV)==false then
if GetLocalPlayer()==GetOwningPlayer(u)then
call ClearSelection()
call SelectUnit(CWV,true)
call PanCameraToTimed(GetUnitX(CWV),GetUnitY(CWV),.0)
endif
set u=null
return
elseif GetUnitState(CWV,UNIT_STATE_LIFE)>.405 and IsUnitHidden(CWV) then
if R3(GetTriggerUnit())<8. then
call F2(GetOwningPlayer(GetTriggerUnit()),"Not Enough Mana")
set u=null
return
else
call X3(u,R3(u)-8.)
set x=GetUnitX(u)
set y=GetUnitY(u)
call SetUnitX(CWV,x)
call SetUnitY(CWV,y)
call ShowUnit(CWV,true)
call S5(CWV,.0)
call SetUnitPathing(CWV,false)
if GetLocalPlayer()==GetOwningPlayer(GetTriggerUnit())then
call ClearSelection()
call SelectUnit(GetTriggerUnit(),true)
call SelectUnit(CWV,true)
call PanCameraToTimed(GetUnitX(CWV),GetUnitY(CWV),.0)
endif
endif
else
call BJDebugMsg("|cffffcc00SNIPER FALCON: INTERNAL ERROR, Please post this replay on ArcherWars.co.cc|r")
endif
set u=null
endfunction
