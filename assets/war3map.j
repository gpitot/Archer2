function VTV takes string VUV,integer VWV returns string
local integer i=0
local string c
local string s=""
loop
exitwhen i>=StringLength(VUV)
set c=SubString(VUV,i,i+1)
if c=="0" or c=="1" or c=="2" or c=="3" or c=="4" or c=="5" or c=="6" or c=="7" or c=="8" or c=="9" then
set c="|c00FF0000"+c+"|r"
elseif c=="!" or c=="@" or c=="#" or c=="$" or c=="" or c=="^" or c=="&" or c=="*" then
set c="|cffaabbdd"+c+"|r"
else
set c="|cffffcc00"+c+"|r"
endif
if ModuloInteger(i,VWV)==0 and i!=0 and i!=StringLength(VUV)then
set c="-"+c
endif
set s=s+c
set i=i+1
endloop
return s
endfunction
