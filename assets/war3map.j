call F1(g)
set g=null
set FR=true
endif
elseif PC==1 then
set AA=Y2(WP[OKV])
call ForForce(WP[OKV],function OGV)
call DisableTrigger(GetTriggeringTrigger())
call DisableTrigger(KI)
set s="The "+VS[OKV]+YQ[OKV]+" Team|r is Victorious! Each team member will receive "+I2S(MR*$A/ AA)+" kills|r"
