function AngleB2 takes real x1,real y1,real x2,real y2 returns real
    return Atan2(y2-y1,x2-x1)*57.3
endfunction

function P7 takes integer ut,unit u,integer I0,real cx,real cy,real tx,real ty,real A0,real r,real N0,real B0,real C0,real D0,real F0,unit G0,unit H0 returns integer
local integer DY
local item B3
local integer Q7
local integer i
local unit ru
local unit tu
local item S7
local integer II
local timer t
local real Y1=P1(cx,cy,tx,ty)
local unit T7
local real ang = AngleB2(cx,cy,tx,ty)
local integer d=K0()
local integer e
if GetUnitTypeId(u)=='H00I' then
set e=QZ(u)
set ru=WG[e]
else
set ru=u
endif
set T7=CreateUnit(GetOwningPlayer(ru),ut,I2(cx,25.,Y1),N2(cy,25.,Y1),Rad2Deg(Y1))
call msgDebug(Id2S(ut))
call msgDebug("Angle: " + R2S(Rad2Deg(Y1)) + " and " + R2S(ang))
if (GetUnitTypeId(T7) == 'h00J') then
    call msgDebug("Reanimation")
    call SetUnitAnimation(T7, "birth")
endif
set Q7=GetUnitAbilityLevel(ru,'A01X')
call L7(T7,d)
set GD[d]=ru
set LD[d]=25.
set DF[d]=.0
set MD[d]=D0
set TD[d]=D0
set AF[d]=false
set QD[d]=Y1
set PD[d]=F0
set EF[d]=D1()
set UD[d]=r
set HD[d]=T7
set JD[d]=I0
set WD[d]=GetUnitX(HD[d])
set YD[d]=GetUnitY(HD[d])
set RF[d]=false
set CF[d]=false
set FF[d]=C0
call GroupAddUnit(GR,HD[d])
set ZD[d]=B0
set KD[d]=N0
set IF[d]=false
set NF[d]=null
set SD[d]=.0
set VF[d]=.0
if Q7==1 then
set BF[d]=true
else
set BF[d]=false
endif
if H0!=null then
set XF[d]=H0
else
set XF[d]=null
endif
if GetUnitTypeId(HD[d])=='h002' then
    call msgDebug("P7 calls O4")
    call O4(function J7,d,.1)
endif
if G0==u then
set DY=0
loop
exitwhen DY>5
set B3=UnitItemInSlot(ru,DY)
if B3!=null then
if GetItemTypeId(B3)=='I005' then
set PD[d]=PD[d]+25.
endif
if GetItemTypeId(B3)=='I00G' or GetItemTypeId(B3)=='I00M' then
set PD[d]=PD[d]+25.
if GetRandomInt(1,'d')<=$F then
call UnitAddItemById(HD[d],'I00V')
endif
endif
if GetItemTypeId(B3)=='I00J' or GetItemTypeId(B3)=='I00M' then
set PD[d]=PD[d]+25.
if GetRandomInt(1,'d')<=$F then
call UnitAddItemById(HD[d],'I00X')
endif
endif
if GetItemTypeId(B3)=='I00F' or GetItemTypeId(B3)=='I00M' then
set PD[d]=PD[d]+25.
if GetRandomInt(1,'d')<=17 then
call UnitAddItemById(HD[d],'I00W')
endif
endif
if GetItemTypeId(B3)=='I007' then
if GetRandomInt(1,'d')<=$A then
call UnitAddItemById(HD[d],'I007')
endif
endif
if GetItemTypeId(B3)=='I006' then
if GetRandomInt(1,'d')<=$F then
call UnitAddItemById(HD[d],'I006')
endif
endif
if GetItemTypeId(B3)=='I008' then
if GetRandomInt(1,'d')<=20 then
call UnitAddItemById(HD[d],'I008')
endif
endif
endif
set DY=DY+1
endloop
set B3=null
else
set tu=G0
if tu!=null and GetUnitState(tu,UNIT_STATE_LIFE)>.405 then
set II=0
set tu=G0
loop
exitwhen II==6
set S7=UnitItemInSlot(tu,II)
call UnitAddItemById(HD[d],GetItemTypeId(S7))
set II=II+1
set S7=null
endloop
endif
endif
set MX=ru
if GetUnitTypeId(HD[d])=='h00K' then
set IF[d]=true
set NF[d]="Abilities\\Spells\\Human\\MarkOfChaos\\MarkOfChaosTarget.mdl"
endif
if BF[d] and GetUnitTypeId(HD[d])!='h00K' then
if GetUnitState(ru,UNIT_STATE_MANA)>=1 then
call SetUnitState(ru,UNIT_STATE_MANA,GetUnitState(ru,UNIT_STATE_MANA)-1)
set KD[d]=KD[d]-7
set ZD[d]=ZD[d]-7
endif
endif
call SetUnitPathing(HD[d],false)
call SetUnitScale(HD[d],1.,1.,1.)
call SetUnitFlyHeight(HD[d],60.,.0)
call O4(function J0,d,A0)
set T7=null
set tu=null
set ru=null
set S7=null
return K7(HD[d])
endfunction
function U7 takes integer ut,unit u,integer I0,real cx,real cy,real tx,real ty,real A0,real r,real N0,real B0,real C0,real D0,real F0,unit G0,unit H0 returns nothing
call P7(ut,u,I0,cx,cy,tx,ty,A0,r,N0,B0,C0,D0,F0,G0,H0)
endfunction
function GroundExpFX takes real x, real y returns nothing
    local effect e = AddSpecialEffect("war3mapImported\\NewGroundEX.mdl",x,y)
    call BlzSetSpecialEffectTimeScale(e, 0.6)
    call DestroyEffect(e)
    set e = null
endfunction
function s__Arrow_Execute takes nothing returns boolean
local real x
local real y
local real cx
local real cy
local real tx
local real ty
local real x2
local real y2
local real a
local unit u
local group g
local group g2
local group g3
local real W7
local real Y7
local real Y1
local integer I0
local integer Q7
local integer Z7
local integer i=0
local real ar
local real V8
local real la
local real ha
local rect r
local integer d=T3()
local integer e
set Z7=GetUnitAbilityLevel(GD[d],'A02C')
set Q7=0
set I0=GetUnitAbilityLevel(GD[d],'A029')
set MX=GD[d]
set x=GetUnitX(HD[d])
set y=GetUnitY(HD[d])
set Y7=Q1(x,y,WD[d],YD[d])
if I0>=1 then
set VF[d]=VF[d]+((Y7/ 80.)*I0)
if VF[d]<200. then
set PD[d]=PD[d]+((Y7/ 80)*I0)
endif
endif
set LD[d]=LD[d]+Y7
set WD[d]=x
set YD[d]=y
if GetUnitState(HD[d],UNIT_STATE_LIFE)<.405 then
set BF[d]=false
call M7(d)
return true
endif
if LD[d]>=MD[d]then
if GetUnitTypeId(HD[d])=='h00N' then
call GroundExpFX(x, y)
set g3=D1()
call GroupEnumUnitsInRange(g3,x,y,200.,Condition(function C7))
loop
set u=FirstOfGroup(g3)
exitwhen u==null
call GroupRemoveUnit(g3,u)
call UnitDamageTarget(HD[d],u,(GetUnitAbilityLevel(GD[d],'A02L')*25.)+100.,false,false,ATTACK_TYPE_CHAOS,DAMAGE_TYPE_UNIVERSAL,null)
endloop
set u=null
call F1(g3)
set g3=null
set r=Rect(x-200.,y-200.,x+200.,y+200.)
call EnumDestructablesInRect(r,Filter(function G7),function H7)
call RemoveRect(r)
set r=null
endif
set BF[d]=false
call M7(d)
return true
endif
if SD[d]!=.0 and GetUnitTypeId(HD[d])!='h00K' then
call SetUnitFacing(HD[d],Rad2Deg(U1(Deg2Rad(GetUnitFacing(HD[d]))+SD[d])))
endif
if GetUnitTypeId(HD[d])=='h00K' then
call SetUnitFacing(HD[d],GetUnitFacing(XF[d]))
endif
set SD[d]=.0
set QD[d]=Deg2Rad(GetUnitFacing(HD[d]))
if XF[d]==null then
set x=I2(x,KD[d],QD[d])
set y=N2(y,KD[d],QD[d])
if(not J1(x)or not L1(y))and CF[d]==false then
set BF[d]=false
call M7(d)
return true
endif
if not J1(x)or not L1(y)and CF[d] then
set x=H1(x)
set y=K1(y)
endif
if KD[d]<ZD[d]then
set KD[d]=KD[d]+FF[d]
endif
elseif XF[d]!=null and GetUnitState(XF[d],UNIT_STATE_LIFE)>.405 then
set e=K7(XF[d])
set GD[d]=GD[e]
set PD[d]=PD[e]/ 2.
set AF[d]=AF[e]
set CF[d]=CF[e]
call SetUnitOwner(HD[d],GetOwningPlayer(HD[e]),true)
set x=I2(GetUnitX(XF[d]),88.,U1(Deg2Rad(GetUnitFacing(XF[d]))+3.1415))
set y=N2(GetUnitY(XF[d]),88.,U1(Deg2Rad(GetUnitFacing(XF[d]))+3.1415))
else
call M7(d)
return true
endif
call SetUnitX(HD[d],x)
call SetUnitY(HD[d],y)
set g=D1()
set g2=D1()
call GroupEnumUnitsInRange(g,x,y,UD[d],Condition(function C7))
call GroupEnumUnitsInRange(g2,x,y,100.,Condition(function F7))
call Q2(g2,g)
call F1(g2)
set g2=null
set u=FirstOfGroup(g)
if u==null then
call GroupClear(EF[d])
endif
loop
set u=FirstOfGroup(g)
exitwhen u==null
if not(IsUnitInGroup(u,EF[d]))then
call GroupAddUnit(EF[d],u)
call UnitDamageTarget(HD[d],u,PD[d],false,false,JX,KX,null)
if RF[d] then
if GetUnitTypeId(HD[d])=='h00N' then
    call GroundExpFX(x, y)
set g3=D1()
call GroupEnumUnitsInRange(g3,x,y,200.,Condition(function C7))
loop
set u=FirstOfGroup(g3)
exitwhen u==null
call GroupRemoveUnit(g3,u)
call UnitDamageTarget(HD[d],u,(GetUnitAbilityLevel(GD[d],'A02L')*25.)+100.,false,false,ATTACK_TYPE_CHAOS,DAMAGE_TYPE_UNIVERSAL,null)
endloop
set u=null
call F1(g3)
set g3=null
set r=Rect(x-200.,y-200.,x+200.,y+200.)
call EnumDestructablesInRect(r,null,function H7)
call RemoveRect(r)
set r=null
endif
set BF[d]=false
call M7(d)
call UnitApplyTimedLife(HD[d],'BTLF',.1)
set u=null
return true
endif
endif
call GroupRemoveUnit(g,u)
endloop
set u=null
call F1(g)
set g=null
if IF[d] and AF[d]==false then
if GetUnitState(HD[d],UNIT_STATE_LIFE)>.405 then
set DF[d]=DF[d]+Y7
if DF[d]>=$FA then
set DF[d]=0
call E6(GD[d],x,y,PD[d]/ 5.)
call DestroyEffect(AddSpecialEffect(NF[d],x,y))
endif
endif
endif
if BF[d] then
set g=D1()
call GroupEnumUnitsInRange(g,x,y,600.,Condition(function D7))
call Q2(GR,g)
loop
set u=FirstOfGroup(g)
if u==HD[d]then
call GroupRemoveUnit(g,u)
set u=FirstOfGroup(g)
endif
exitwhen u==null
set x2=GetUnitX(u)
set y2=GetUnitY(u)
set W7=Q1(x,y,x2,y2)
if W7<=600. then
set a=P1(x2,y2,x,y)
if 400./ W7<=W7 then
set x2=H1(I2(x2,(KD[d]/(W7/ KD[d]*2.)),a))
set y2=K1(N2(y2,(KD[d]/(W7/ KD[d]*2.)),a))
endif
call SetUnitX(u,x2)
call SetUnitY(u,y2)
endif
call GroupRemoveUnit(g,u)
endloop
set u=null
call F1(g)
set g=null
endif
set u=null
return false
endfunction
function X8 takes nothing returns nothing
local weathereffect we
set RO=Rect(-1408.,-3168.,-864.,-2688.)
set we=AddWeatherEffect(RO,'LRaa')
call EnableWeatherEffect(we,true)
set IO=Rect(2400.,-5984.,2560.,-5824.)
set AO=Rect(2560.,-6016.,2752.,-5824.)
set NO=Rect(-2784.,-6720.,4416.,512.)
set BO=Rect(6496.,-8384.,16192.,-96.)
set CO=Rect(4192.,-21216.,16288.,-9056.)
endfunction
function O8 takes nothing returns string
local string s=""
local integer i=0
loop
exitwhen i>=OO
set s=s+I2S(XO[i])
set i=i+1
endloop
return s
endfunction
function R8 takes nothing returns nothing
set WX=0
endfunction
function I8 takes nothing returns nothing
set OO=0
endfunction
function A8 takes nothing returns nothing
local integer i=0
loop
exitwhen i>=WX
set XO[i]=UX[i]
set i=i+1
endloop
set OO=WX
call R8()
endfunction
function N8 takes nothing returns nothing
local integer i=0
loop
exitwhen i>=WX
set XO[i]=UX[WX-1-i]
set i=i+1
endloop
set OO=WX
call R8()
endfunction
function B8 takes integer DY returns integer
if DY>=OO then
return 0
endif
return XO[DY]
endfunction
function C8 takes integer DY,integer D8 returns nothing
if DY>=OO and D8==1 then
loop
set OO=OO+1
exitwhen OO>DY
set XO[OO-1]=0
endloop
endif
if DY==OO-1 and D8==0 then
loop
set OO=OO-1
exitwhen XO[OO-1]==1 or OO==0
endloop
else
set XO[DY]=D8
endif
endfunction
function F8 takes integer DY returns integer
if DY>=WX then
return 0
endif
return UX[DY]
endfunction
function G8 takes integer DY,integer D8 returns nothing
if DY>=WX and D8==1 then
loop
set WX=WX+1
exitwhen WX>DY
set UX[WX-1]=0
endloop
endif
if DY==WX-1 and D8==0 then
loop
set WX=WX-1
exitwhen UX[WX-1]==1 or WX==0
endloop
else
set UX[DY]=D8
endif
endfunction
function H8 takes integer MI,integer J8 returns integer
local integer i=0
local integer K8=0
loop
exitwhen i>=J8-MI
set K8=K8*2
set K8=K8+B8(J8-i-1)
set i=i+1
endloop
return K8
endfunction
function L8 takes integer K8 returns integer
local integer i=0
loop
exitwhen K8==0
set K8=K8/ 2
set i=i+1
endloop
return i
endfunction
function M8 takes integer K8,integer MI,integer J8 returns nothing
local integer i=0
loop
exitwhen i>J8-MI
call C8(MI+i,ModuloInteger(K8,2))
set K8=K8/ 2
set i=i+1
endloop
endfunction
function P8 takes integer K8 returns nothing
local integer Q8=0
local integer i=0
loop
exitwhen K8==0 and Q8==0
set Q8=Q8+ModuloInteger(K8,2)+B8(i)
call C8(i,ModuloInteger(Q8,2))
set Q8=Q8/ 2
set K8=K8/ 2
set i=i+1
endloop
endfunction
function S8 takes integer K8 returns nothing
local integer Q8
local integer i=0
local integer j
loop
exitwhen K8==0
if ModuloInteger(K8,2)==1 then
set Q8=0
set j=0
loop
exitwhen j>=OO and Q8==0
set Q8=Q8+B8(j)+F8(i+j)
call G8(i+j,ModuloInteger(Q8,2))
set Q8=Q8/ 2
set j=j+1
endloop
endif
set K8=K8/ 2
set i=i+1
endloop
call A8()
endfunction
function T8 takes nothing returns nothing
call S8(bj_forceCountPlayers)
endfunction
function U8 takes integer K8 returns nothing
set bj_forceCountPlayers=K8
call ExecuteFunc("T8")
endfunction
function W8 takes integer K8 returns integer
local integer i=0
local integer Y8=OO
local integer d
local integer Z8=L8(K8)
loop
exitwhen Y8<i+Z8
set d=H8(Y8-i-Z8,OO)
if d>=K8 then
call M8(d-K8,Y8-i-Z8,OO)
set UX[i]=1
else
set UX[i]=0
endif
set i=i+1
endloop
set WX=i
set d=H8(0,OO)
call N8()
return d
endfunction
