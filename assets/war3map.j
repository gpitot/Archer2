function XRV takes nothing returns nothing
local multiboarditem X5=null
local integer XIV=GetPlayerId(GetOwningPlayer(GetKillingUnit()))
local integer XAV=GetPlayerId(GetOwningPlayer(GetTriggerUnit()))
local integer XNV=0
local integer i=0
local integer l1
local integer l2
local integer l
local string s
local integer d
if(GetPlayerSlotState(GetOwningPlayer(GetTriggerUnit()))==PLAYER_SLOT_STATE_PLAYING and GetPlayerController(GetOwningPlayer(GetTriggerUnit()))==MAP_CONTROL_USER and IsUnitType(GetTriggerUnit(),UNIT_TYPE_HERO)and GetUnitPointValue(GetTriggerUnit())=='d')and(GetPlayerSlotState(GetOwningPlayer(GetKillingUnit()))==PLAYER_SLOT_STATE_PLAYING and GetPlayerController(GetOwningPlayer(GetKillingUnit()))==MAP_CONTROL_USER)then
if IsPlayerEnemy(GetOwningPlayer(GetKillingUnit()),GetOwningPlayer(GetTriggerUnit())) then
set EQ[XAV]=(EQ[XAV]+1)
set GQ[XAV]=(GQ[XAV]+1)
set AQ[XIV]=AQ[XIV]+1
set HQ[XIV]=HQ[XIV]+1
call E5(GetOwningPlayer(GetTriggerUnit()))
call O5(GetOwningPlayer(GetTriggerUnit()))
call E5(GetOwningPlayer(GetKillingUnit()))
call O5(GetOwningPlayer(GetKillingUnit()))
call R5(GetOwningPlayer(GetKillingUnit()))
call R5(GetOwningPlayer(GetTriggerUnit()))
set l1=GetHeroLevel(NS[XIV])
set l2=GetHeroLevel(NS[XAV])
if l1>l2 then
set l=l1-l2
call SetHeroXP(NS[XAV],GetHeroXP(NS[XAV])+(l*50),false)
endif
if PR!=$C then
set i=0
loop
exitwhen i==7
call I5(i)
set i=i+1
endloop
endif
set LR=LR+1
set s=ES[GetPlayerId(GetOwningPlayer(GetDyingUnit()))]+GetPlayerName(GetOwningPlayer(GetDyingUnit()))+"|r has been pwned by "+ES[GetPlayerId(GetOwningPlayer(GetKillingUnit()))]+GetPlayerName(GetOwningPlayer(GetKillingUnit()))+"|r for |cffffcc005 gold!|r"
call DisplayTimedTextFromPlayer(GetLocalPlayer(),.0,.0,WQ[GetPlayerId(GetLocalPlayer())],s)
call SetPlayerState(GetOwningPlayer(GetKillingUnit()),PLAYER_STATE_RESOURCE_GOLD,GetPlayerState(GetOwningPlayer(GetKillingUnit()),PLAYER_STATE_RESOURCE_GOLD)+5)
if LR==1 then
call StartSound(TO)
set s=ES[GetPlayerId(GetOwningPlayer(GetKillingUnit()))]+GetPlayerName(GetOwningPlayer(GetKillingUnit()))+"|r has received |c00FF0000FIRST BLOOD!!|r |cffffcc00+5 gold!|r"
call DisplayTimedTextFromPlayer(GetLocalPlayer(),.0,.0,WQ[GetPlayerId(GetLocalPlayer())],s)
call SetPlayerState(GetOwningPlayer(GetKillingUnit()),PLAYER_STATE_RESOURCE_GOLD,GetPlayerState(GetOwningPlayer(GetKillingUnit()),PLAYER_STATE_RESOURCE_GOLD)+5)
endif
if DQ[XAV]>3 then
if DQ[XAV]>$A then
set DQ[XAV]=$A
endif
if OQ[XAV]>0 then
set XNV=US[DQ[XAV]]+(7*(OQ[XAV]-1))
else
set XNV=US[DQ[XAV]]
endif
set s=ES[XAV]+GetPlayerName(GetOwningPlayer(GetDyingUnit()))+"|r's "+QS[DQ[XAV]]+" has been ended by "+ES[XIV]+GetPlayerName(GetOwningPlayer(GetKillingUnit()))+"|r |cffffcc00+"+I2S(XNV)+" gold!|r"
call DisplayTimedTextFromPlayer(GetLocalPlayer(),.0,.0,WQ[GetPlayerId(GetLocalPlayer())],s)
call SetPlayerState(GetOwningPlayer(GetKillingUnit()),PLAYER_STATE_RESOURCE_GOLD,GetPlayerState(GetOwningPlayer(GetKillingUnit()),PLAYER_STATE_RESOURCE_GOLD)+XNV)
call DestroyEffect(UP[XAV])
endif
set DQ[XAV]=0
set OQ[XAV]=0
set NQ[XAV]=0
set DQ[XIV]=DQ[XIV]+1
if DQ[XIV]>$A then
set DQ[XIV]=$A
endif
if DQ[XIV]>3 then
call StartSound(SS[DQ[XIV]])
call SetPlayerState(GetOwningPlayer(GetKillingUnit()),PLAYER_STATE_RESOURCE_GOLD,GetPlayerState(GetOwningPlayer(GetKillingUnit()),PLAYER_STATE_RESOURCE_GOLD)+TS[DQ[XIV]])
if DQ[XIV]==4 then
set UP[XIV]=AddSpecialEffectTarget("Abilities\\Spells\\Items\\HealingSalve\\HealingSalveTarget.mdl",NS[XIV],"origin")
endif
if DQ[XIV]==$A then
set OQ[XIV]=OQ[XIV]+1
endif
if OQ[XIV]>0 then
set XNV=US[DQ[XIV]]+(7*(OQ[XIV]-1))
else
set XNV=US[DQ[XIV]]
endif
set s=ES[XIV]+GetPlayerName(GetOwningPlayer(GetKillingUnit()))+"|r"+PS[DQ[XIV]]+" |cffffcc00("+I2S(XNV)+" Bounty)|r"
call DisplayTimedTextFromPlayer(GetLocalPlayer(),.0,.0,WQ[GetPlayerId(GetLocalPlayer())],s)
endif
set NQ[XIV]=NQ[XIV]+1
if PQ[XIV]<=.0 then
set d=ZZ()
set WF[d]=Player(XIV)
call O4(function XOV,d,.1)
endif
set PQ[XIV]=1.
if NQ[XIV]>3 then
set NQ[XIV]=3
endif
if NQ[XIV]>1 then
call StartSound(YS[NQ[XIV]])
call SetPlayerState(GetOwningPlayer(GetKillingUnit()),PLAYER_STATE_RESOURCE_GOLD,GetPlayerState(GetOwningPlayer(GetKillingUnit()),PLAYER_STATE_RESOURCE_GOLD)+ZS[NQ[XIV]])
set s=ES[XIV]+GetPlayerName(GetOwningPlayer(GetKillingUnit()))+"|r"+WS[NQ[XIV]]
call DisplayTimedTextFromPlayer(GetLocalPlayer(),.0,.0,WQ[GetPlayerId(GetLocalPlayer())],s)
endif
set i=0
loop
exitwhen i==$C
if HQ[GetPlayerId(GetOwningPlayer(GetKillingUnit()))]==CT[i]then
    call msgDebug("XRV " + (XS[GetPlayerId(GetOwningPlayer(GetKillingUnit()))]+NT[i]))
call SetPlayerName(GetOwningPlayer(GetKillingUnit()),(XS[GetPlayerId(GetOwningPlayer(GetKillingUnit()))]+NT[i]))
set s=ES[GetPlayerId(GetOwningPlayer(GetKillingUnit()))]+XS[GetPlayerId(GetOwningPlayer(GetKillingUnit()))]+"|r has ranked up to a(n)|cffffcc00"+NT[i]+"|r"
call DisplayTimedTextFromPlayer(GetLocalPlayer(),.0,.0,WQ[GetPlayerId(GetLocalPlayer())],s)
set X5=MultiboardGetItem(LQ[GetPlayerId(GetOwningPlayer(GetKillingUnit()))],1,1)
call MultiboardSetItemValue(X5,NT[i])
call MultiboardReleaseItem(X5)
set X5=null
endif
set i=i+1
endloop
else
set EQ[XAV]=(EQ[XAV]+1)
set GQ[XAV]=(GQ[XAV]+1)
if GetOwningPlayer(GetKillingUnit())!=GetOwningPlayer(GetTriggerUnit())then
set s=ES[GetPlayerId(GetOwningPlayer(GetDyingUnit()))]+GetPlayerName(GetOwningPlayer(GetDyingUnit()))+"|r has been denied by "+ES[GetPlayerId(GetOwningPlayer(GetKillingUnit()))]+GetPlayerName(GetOwningPlayer(GetKillingUnit()))+"|r"
else
set s=ES[GetPlayerId(GetOwningPlayer(GetDyingUnit()))]+GetPlayerName(GetOwningPlayer(GetDyingUnit()))+"|r has denied himself/herself"
endif
call DisplayTimedTextFromPlayer(GetLocalPlayer(),.0,.0,WQ[GetPlayerId(GetLocalPlayer())],s)
endif
set i=0
loop
exitwhen i==$C
if IsPlayerInForce(Player(XIV),WP[i])then
set XQ[i]=XQ[i]+1
endif
set i=i+1
endloop
endif
if DM then
call TriggerExecute(BI)
endif
set X5=null
endfunction
function XBV takes nothing returns boolean
local real x=GetUnitX(GetFilterUnit())
local real y=GetUnitY(GetFilterUnit())
return IsUnitEnemy(GetFilterUnit(),GetOwningPlayer(XA))and GetFilterUnit()!=EA and GetWidgetLife(GetFilterUnit())>.405 and(IsUnitVisible(GetFilterUnit(),GetOwningPlayer(XA))or not UnitHasBuffBJ(GetFilterUnit(),'BOwk'))and GetUnitAbilityLevel(GetFilterUnit(),'Avul')==0 and IsTerrainPathable(x,y,PATHING_TYPE_FLOATABILITY)==false
endfunction
function XCV takes nothing returns boolean
return IsUnitEnemy(GetFilterUnit(),GetOwningPlayer(XA))and GetFilterUnit()!=EA and GetWidgetLife(GetFilterUnit())>.405 and(IsUnitVisible(GetFilterUnit(),GetOwningPlayer(XA))or not UnitHasBuffBJ(GetFilterUnit(),'BOwk'))and GetUnitAbilityLevel(GetFilterUnit(),'Avul')==0
endfunction
function XDV takes unit TY returns integer
local integer J5=J4(TY)
if XG[J5]!=0 then
if EG[J5]!=TY then
call YZ(XG[J5])
set EG[J5]=null
set XG[J5]=0
endif
endif
return XG[J5]
endfunction
function XFV takes unit TY,integer UY returns nothing
local integer J5=J4(TY)
if XG[J5]!=0 then
call YZ(XG[J5])
endif
set EG[J5]=TY
set XG[J5]=UY
set OG[UY]=J5
endfunction
function XGV takes integer LY returns nothing
local integer J5=OG[(LY)]
call YZ(LY)
set EG[J5]=null
set XG[J5]=0
endfunction
function XJV takes nothing returns boolean
local integer d=T3()
local texttag XKV
local real x=GetUnitX(RG[d])
local real y=GetUnitY(RG[d])
local integer i=0

call msgTimer("XJV Start")
set CG[d]=CG[d]-.05
if CG[d]>0 then
return false
endif
set XKV=CreateTextTag()
if BG[d] then
call SetTextTagText(XKV,"|cffffcc00Critical!|r |c00FF0000-"+I2S(R2I(AG[d]))+"|r",.023)
else
call SetTextTagText(XKV,"|c00FF0000-"+I2S(R2I(AG[d]))+"|r",.023)
endif
call SetTextTagPos(XKV,x,y,150.)
call SetTextTagVelocity(XKV,(64.*.071/ 128.)*Cos(90.*3.14/ 180.),(64.*.071/ 128.)*Sin(90.*3.14/ 180.))
call SetTextTagPermanent(XKV,false)
call SetTextTagLifespan(XKV,1.7)
call SetTextTagFadepoint(XKV,1.)
if(IsFoggedToPlayer(x,y,GetLocalPlayer())or IsMaskedToPlayer(x,y,GetLocalPlayer()))and GetLocalPlayer()!=GetOwningPlayer(IG[d])then
call SetTextTagVisibility(XKV,false)
endif
set BG[d]=false
set XKV=null
set AG[d]=0
call XGV(d)
return true
endfunction
function XLV takes nothing returns nothing
local unit u=GetTriggerUnit()
local unit ds=GetEventDamageSource()
local real x=GetUnitX(u)
local real y=GetUnitY(u)
local real x1
local real y1
local real x2
local real y2
local group g
local group g2
local integer i
local integer n
local real W7
local unit R1
local unit Y4
local real XMV
local real ms
local multiboarditem X5=null
local integer d=XDV(u)
local integer e
local integer c
set EA=u
set XA=ds
call DestroyEffect(AddSpecialEffectTarget("Objects\\Spawnmodels\\NightElf\\NightElfBlood\\NightElfBloodArcher.mdl",u,"origin"))
if d==0 then
set d=WZ()
set RG[d]=u
set IG[d]=GetEventDamageSource()
set AG[d]=0
call XFV(u,d)
set CG[d]=.1
call O4(function XJV,d,.05)
else
set CG[d]=.1
call TimerStart(NG[d],.1,false,function XJV)
endif
set AG[d]=AG[d]+GetEventDamage()
if GetUnitTypeId(ds)=='h00J' or GetUnitTypeId(ds)=='h002' then
set RQ[GetPlayerId(GetOwningPlayer(ds))]=RQ[GetPlayerId(GetOwningPlayer(ds))]+1
if BQ[GetPlayerId(GetOwningPlayer(ds))]==0 then
set XMV=I2R(RQ[GetPlayerId(GetOwningPlayer(ds))])*'d'
else
set XMV=(I2R(RQ[GetPlayerId(GetOwningPlayer(ds))])/ I2R(BQ[GetPlayerId(GetOwningPlayer(ds))]))*'d'
endif
set X5=MultiboardGetItem(LQ[GetPlayerId(GetOwningPlayer(ds))],8,1)
call MultiboardSetItemValue(X5,I2S(R2I(XMV))+"%")
call MultiboardReleaseItem(X5)
set X5=null
set e=K7(ds)
set Y4=CreateUnit(GetOwningPlayer(ds),'h00A',x,y,.0)
if A3(GD[e],'I00P')>=1 or A3(GD[e],'I00T')>=1 then
if GetRandomInt(1,'d')<=25 then
set ms=GetEventDamage()/ 50.
if GetUnitState(u,UNIT_STATE_MANA)<ms then
set ms=GetUnitState(u,UNIT_STATE_MANA)
endif
call SetUnitState(u,UNIT_STATE_MANA,GetUnitState(u,UNIT_STATE_MANA)-ms)
call SetUnitState(GD[e],UNIT_STATE_MANA,GetUnitState(GD[e],UNIT_STATE_MANA)+ms)
call DestroyEffect(AddSpecialEffectTarget("Abilities\\Spells\\Human\\SpellSteal\\SpellStealTarget.mdl",GetTriggerUnit(),"chest"))
call DestroyEffect(AddSpecialEffectTarget("Abilities\\Spells\\NightElf\\MoonWell\\MoonWellCasterArt.mdl",GD[e],"chest"))
endif
endif
if A3(GD[e],'I00L')>=1 and GetWidgetLife(GD[e])>.405 then
call SetUnitState(GD[e],UNIT_STATE_LIFE,GetUnitState(GD[e],UNIT_STATE_LIFE)+(.2*GetEventDamage()))
call DestroyEffect(AddSpecialEffectTarget("Abilities\\Spells\\Undead\\VampiricAura\\VampiricAuraTarget.mdl",GD[e],"origin"))
endif
set Y4=null
if A3(ds,'I00V')>=1 then
set Y4=CreateUnit(GetOwningPlayer(ds),'h00A',x,y,.0)
call UnitAddAbility(Y4,'A00I')
call UnitAddAbility(Y4,'A01M')
call UnitApplyTimedLife(Y4,'BTLF',2.)
call IssueTargetOrderById(Y4,$D0102,u)
set g=D1()
set EA=u
set XA=ds
call GroupEnumUnitsInRange(g,x,y,$C8,Condition(function XCV))
loop
set R1=FirstOfGroup(g)
exitwhen R1==null
if R1==u then
call UnitDamageTarget(Y4,R1,PD[e]/ 6.,false,false,ATTACK_TYPE_CHAOS,DAMAGE_TYPE_UNIVERSAL,null)
else
call UnitDamageTarget(Y4,R1,PD[e]/ 9.,false,false,ATTACK_TYPE_CHAOS,DAMAGE_TYPE_UNIVERSAL,null)
endif
call GroupRemoveUnit(g,R1)
endloop
call F1(g)
set g=null
if IsTerrainPathable(x,y,PATHING_TYPE_FLOATABILITY)==false then
call IssueTargetOrderById(Y4,$D007F,u)
endif
endif
set Y4=null
if A3(ds,'I00X')>=1 then
call DestroyEffect(AddSpecialEffectTarget("Abilities\\Spells\\Other\\Monsoon\\MonsoonBoltTarget.mdl",GetTriggerUnit(),"origin"))
set Y4=CreateUnit(GetOwningPlayer(ds),'h00A',x,y,.0)
call UnitApplyTimedLife(Y4,'BTLF',2.)
call UnitDamageTarget(Y4,u,100.,false,false,ATTACK_TYPE_CHAOS,DAMAGE_TYPE_UNIVERSAL,null)
if IsTerrainPathable(x,y,PATHING_TYPE_FLOATABILITY)==false then
set g=D1()
set EA=u
set XA=ds
call GroupEnumUnitsInRange(g,x,y,5000,Condition(function XBV))
loop
set R1=FirstOfGroup(g)
exitwhen R1==null
call DestroyEffect(AddSpecialEffectTarget("Abilities\\Spells\\Other\\Monsoon\\MonsoonBoltTarget.mdl",R1,"origin"))
set x1=GetUnitX(R1)
set y1=GetUnitY(R1)
set W7=Q1(x,y,x1,y1)
call UnitDamageTarget(Y4,R1,(PD[e]*100.)/ W7,false,false,ATTACK_TYPE_CHAOS,DAMAGE_TYPE_UNIVERSAL,null)
call GroupRemoveUnit(g,R1)
endloop
call F1(g)
set g=null
endif
endif
set Y4=null
if A3(ds,'I00W')>=1 then
set Y4=CreateUnit(GetOwningPlayer(ds),'h00A',x,y,.0)
call UnitAddAbility(Y4,'A014')
call UnitApplyTimedLife(Y4,'BTLF',15.)
if GetUnitTypeId(u)!='e009' then
call C5(Y4,u,PD[e]/ 40.,1,$A)
endif
if IsTerrainPathable(x,y,PATHING_TYPE_FLOATABILITY) then
set i=1
loop
exitwhen i>20
set x1=I2(x,200.,18.*I2R(i))
set y1=N2(y,200.,18.*I2R(i))
call SetUnitX(Y4,x1)
call SetUnitY(Y4,y1)
set x2=I2(x,250.,18.*I2R(i))
set y2=N2(y,250.,18.*I2R(i))
