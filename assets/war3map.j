function C7 takes nothing returns boolean
return(IsUnitEnemy(GetFilterUnit(),GetOwningPlayer(MX))and GetWidgetLife(GetFilterUnit())>.405)and(IsUnitVisible(GetFilterUnit(),GetOwningPlayer(MX))or not UnitHasBuffBJ(GetFilterUnit(),'BOwk')or GetUnitTypeId(GetFilterUnit())=='oeye')and GetUnitAbilityLevel(GetFilterUnit(),'Avul')==0
endfunction
