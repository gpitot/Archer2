function V2V takes integer K8,integer V3V,integer V0V returns nothing
local integer i=0
local integer p
local integer p2=R2I(Pow(V3V,V0V))
if K8>=p2 then
set i=V0V-1
set p=R2I(Pow(V3V,i))
set K8=p2-1
else
set p=1
loop
set p2=p*V3V
exitwhen p2>K8
set p=p2
set i=i+1
endloop
endif
call V_V(K8-p+1,p2-p+1)
call V_V(i,V0V)
endfunction
function V4V takes integer V3V,integer V0V returns integer
