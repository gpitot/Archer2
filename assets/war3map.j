function VPV takes string s returns integer
local integer i=0
local integer j
local integer VQV=0
local string c
loop
exitwhen i>=StringLength(s)
set c=SubString(s,i,i+1)
if c!="-" then
set j=0
loop
exitwhen j>=StringLength(YX)or SubString(YX,j,j+1)==c or SubString("abcdefghijklmnopqrstuvwxyz",j,j+1)==c
set j=j+1
endloop
call U8(StringLength(YX))
call P8(j)
set VQV=VQV+1
endif
set i=i+1
endloop
return VQV
endfunction
