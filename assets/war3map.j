set IV[ZV]=CreateTimer()
set AV[ZV]=CreateTrigger()
endif
if LV==1 then
set JV=JV+1
set VE=JV
else
set LV=LV-1
set VE=KV[LV]
endif
set DV[VE]=And(Condition(Q3),EE)
if UV==ZV then
set TV=TV+1
set SV[TV]=true
set MV[TV]=VE
else
if NV[ZV]<1 then
call TimerStart(IV[ZV],ZV/ 800.,true,function L3)
set BV[ZV]=VE
endif
set CV[VE]=TriggerAddCondition(AV[ZV],DV[VE])
endif
set FV[VE]=S3
set HV[VE]=0
set GV[VE]=NV[ZV]
set HV[NV[ZV]]=VE
set NV[ZV]=VE
