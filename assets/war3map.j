set QE=QE+1
if WE>0 then
set TE[QE]=YE[WE]
set WE=WE-1
else
set PE=PE+1
set TE[QE]=PE
endif
set UE[QE]=TY
call SetUnitUserData(TY,TE[QE])
set DY=GetUnitUserData(TY)
if DY==0 then
