set X5=MultiboardGetItem(LQ[i],$A,0)
call MultiboardSetItemValue(X5,"|c003366CCItems:|r")
call MultiboardReleaseItem(X5)
set X5=MultiboardGetItem(LQ[i],$A,1)
call MultiboardSetItemIcon(X5,ZQ[35])
call MultiboardSetItemStyle(X5,false,true)
call MultiboardSetItemWidth(X5,.01)
call MultiboardReleaseItem(X5)
set X5=MultiboardGetItem(LQ[i],$A,2)
call MultiboardSetItemIcon(X5,ZQ[35])
call MultiboardSetItemStyle(X5,false,true)
call MultiboardSetItemWidth(X5,.01)
call MultiboardReleaseItem(X5)
set X5=MultiboardGetItem(LQ[i],$B,1)
call MultiboardSetItemIcon(X5,ZQ[35])
call MultiboardSetItemStyle(X5,false,true)
call MultiboardSetItemWidth(X5,.01)
call MultiboardReleaseItem(X5)
set X5=MultiboardGetItem(LQ[i],$B,2)
call MultiboardSetItemIcon(X5,ZQ[35])
call MultiboardSetItemStyle(X5,false,true)
call MultiboardSetItemWidth(X5,.01)
call MultiboardReleaseItem(X5)
set X5=MultiboardGetItem(LQ[i],$C,1)
call MultiboardSetItemIcon(X5,ZQ[35])
call MultiboardSetItemStyle(X5,false,true)
call MultiboardSetItemWidth(X5,.01)
call MultiboardReleaseItem(X5)
set X5=MultiboardGetItem(LQ[i],$C,2)
call MultiboardSetItemIcon(X5,ZQ[35])
call MultiboardSetItemStyle(X5,false,true)
call MultiboardSetItemWidth(X5,.01)
call MultiboardReleaseItem(X5)
set X5=MultiboardGetItem(LQ[i],$E,0)
call MultiboardSetItemStyle(X5,true,false)
call MultiboardSetItemWidth(X5,.19)
call MultiboardSetItemValue(X5,"|c0033CCFFPush Left Arrow for Single|r")
call MultiboardReleaseItem(X5)
set X5=MultiboardGetItem(LQ[i],$E,1)
call MultiboardSetItemStyle(X5,true,false)
call MultiboardSetItemWidth(X5,.0)
call MultiboardReleaseItem(X5)
set X5=MultiboardGetItem(LQ[i],$E,2)
call MultiboardSetItemStyle(X5,true,false)
call MultiboardSetItemWidth(X5,.0)
call MultiboardReleaseItem(X5)
set X5=MultiboardGetItem(LQ[i],$F,0)
call MultiboardSetItemStyle(X5,true,false)
call MultiboardSetItemWidth(X5,.19)
call MultiboardSetItemValue(X5,"|c0033CCFFPush Up/Down Arrow to cycle|r")
call MultiboardReleaseItem(X5)
set X5=MultiboardGetItem(LQ[i],$F,1)
call MultiboardSetItemStyle(X5,true,false)
call MultiboardSetItemWidth(X5,.0)
call MultiboardReleaseItem(X5)
set X5=MultiboardGetItem(LQ[i],$F,2)
call MultiboardSetItemStyle(X5,true,false)
call MultiboardSetItemWidth(X5,.0)
call MultiboardReleaseItem(X5)
else
set LQ[i]=null
endif
set i=i+1
endloop
set X5=null
endfunction
