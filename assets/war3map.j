function CZV takes nothing returns nothing
local integer a=GetUnitAbilityLevel(GetTriggerUnit(),'A02F')
local unit f=AS[GetPlayerId(GetOwningPlayer(GetTriggerUnit()))]
if f!=null then
if a==2 then
call UnitAddAbility(f,'A01N')
endif
if a==3 then
call UnitAddAbility(f,'A00U')
call UnitAddAbility(f,'A00S')
call SetPlayerAbilityAvailable(GetOwningPlayer(GetTriggerUnit()),'A00U',true)
call SetPlayerAbilityAvailable(GetOwningPlayer(GetTriggerUnit()),'A00S',false)
call SetUnitAbilityLevel(f,'A00S',2)
endif
if a==4 then
call UnitAddAbility(f,'A02M')
endif
endif
set f=null
endfunction
