function R_V takes nothing returns nothing
local player p=GetOwningPlayer(GetTriggerUnit())
local real x=GetLocationX(GetSpellTargetLoc())
local real y=GetLocationY(GetSpellTargetLoc())
local unit w
if GetPlayerState(p,PLAYER_STATE_RESOURCE_GOLD)>=5 then
call SetPlayerState(p,PLAYER_STATE_RESOURCE_GOLD,GetPlayerState(p,PLAYER_STATE_RESOURCE_GOLD)-5)
set w=CreateUnit(p,'oeye',x,y,.0)
call UnitApplyTimedLife(w,'BTLF',300.)
call S5(w,.0)
call SetUnitPathing(w,false)
else
call F2(p,"Not Enough Gold")
endif
set p=null
set w=null
endfunction
function R0V takes nothing returns boolean
return GetSpellAbilityId()=='A02Q'
endfunction
function R1V takes nothing returns nothing
