set A9V=N2(ty,350.,(A5V-.34906))
call U7('h00J',u,i,cx,cy,tx,ty,.03,60.,33.,33.,.3,A3V(i),A2V(i),u,null)
call U7('h00J',u,i,cx,cy,A6V,A7V,.03,60.,33.,33.,.3,A3V(i),A2V(i),u,null)
call U7('h00J',u,i,cx,cy,A8V,A9V,.03,60.,33.,33.,.3,A3V(i),A2V(i),u,null)
