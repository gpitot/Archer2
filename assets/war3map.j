endif
set u=GetEnumUnit()
call SetWidgetLife(u,GetUnitState(u,UNIT_STATE_MAX_LIFE))
call SetUnitState(u,UNIT_STATE_MANA,GetUnitState(u,UNIT_STATE_MAX_MANA))
set u=null
endfunction
function OSV takes nothing returns boolean
return(IsUnitType(GetFilterUnit(),UNIT_TYPE_HERO)and GetWidgetLife(GetFilterUnit())>.405)!=null
endfunction
function OTV takes nothing returns nothing
call GroupClear(DA)
call GroupEnumUnitsOfPlayer(DA,GetEnumPlayer(),Filter(function OSV))
set XT[GA]=XT[GA]+CountUnitsInGroup(DA)
endfunction
function OUV takes nothing returns nothing
local integer i=0
loop
exitwhen i==$C
set XT[i]=0
if Y2(WP[i])>0 and WP[i]!=null then
set ET[i]=true
set GA=i
call ForForce(WP[i],function OTV)
else
set ET[i]=false
endif
set i=i+1
endloop
endfunction
function OWV takes nothing returns nothing
    call msgTimer("OWV Start")
set KA=KA-1
call DisplayTimedTextFromPlayer(GetLocalPlayer(),0,0,5.,"|cffffcc00"+I2S(KA)+"|r")
if KA==0 then
call PauseTimer(CA)
call GY(2)
endif
call msgTimer("OWV Finish")
endfunction
function OYV takes nothing returns nothing
local integer i=0
local string s="|cffffcc00Current Scores (Win: "+I2S(SR)+"):|r "
local player p
call OUV()
loop
exitwhen i==$C
if ET[i] then
if PR==$C then
set p=P2(WP[i])
set s=s+ES[i]+XS[GetPlayerId(p)]+": "+I2S(OT[i])+"|r "
set p=null
else
set s=s+VS[i]+YQ[i]+" Team: "+I2S(OT[i])+"|r "
endif
endif
set i=i+1
endloop
call PauseTimer(CA)
call TimerStart(CA,1.,true,function OWV)
set KA=6
call DisplayTimedTextFromPlayer(GetLocalPlayer(),0,0,5.,s)
call DisplayTimedTextFromPlayer(GetLocalPlayer(),0,0,5.,"|cffffcc00Next Round in 5 seconds.|r")
set LA=false
endfunction
function OZV takes nothing returns nothing
call DisplayTimedTextFromPlayer(GetLocalPlayer(),0,0,5.,"|c00ff0000Round Draw.|r")
call OYV()
endfunction
function O_V takes nothing returns nothing
    call msgTimer("O_V Start")
set BA=BA-1.
if BA>0 then
if IsPlayerInForce(GetLocalPlayer(),bj_FORCE_ALL_PLAYERS)then
call LeaderboardSetItemValue(lb,LeaderboardGetPlayerIndex(lb,GetLocalPlayer()),R2I(BA))
endif
else
call LeaderboardDisplay(lb,false)
call OZV()
endif
call msgTimer("O_V")
endfunction
function O0V takes nothing returns nothing
if IsPlayerInForce(GetLocalPlayer(),bj_FORCE_ALL_PLAYERS)then
call LeaderboardClear(lb)
call PlayerSetLeaderboard(GetLocalPlayer(),lb)
call LeaderboardSetStyle(lb,true,true,true,false)
call LeaderboardAddItem(lb,"Round Ends In:",R2I(180.),GetLocalPlayer())
call LeaderboardDisplay(lb,true)
endif
set BA=180.
call TimerStart(CA,1.,true,function O_V)
call DisplayTimedTextFromPlayer(GetLocalPlayer(),0,0,5.,"|cffffcc00Round Start!|r")
set LA=true
endfunction
function O1V takes nothing returns nothing
if GetEnumPlayer()!=PA then
     
call SetPlayerAlliance(GetEnumPlayer(),PA,ALLIANCE_SHARED_VISION,true)
call SetPlayerAlliance(PA,GetEnumPlayer(),ALLIANCE_SHARED_VISION,true)
 
endif
endfunction
function O2V takes nothing returns nothing
set PA=GetEnumPlayer()
call ForForce(JA,function O1V)
endfunction
function RoundPrepare takes nothing returns nothing
local integer i=0
local integer i2=0
local unit Y4
local item ti=null
call TriggerExecute(RS)
call TriggerSleepAction(1)
loop
exitwhen i==$C
if GetWidgetLife(IS[i])>.405 then
call ShowUnit(IS[i],false)
call SetUnitX(IS[i],FS[i])
call SetUnitY(IS[i],GS[i])
call ShowUnit(IS[i],true)
if GetWidgetLife(NS[i])<.405 then
call ReviveHero(NS[i],FS[i],GS[i],true)
set Y4=BS[i]
call EIV(NS[i])
set i2=0
loop
exitwhen i2==6
set ti=UnitItemInSlot(Y4,i2)
if ti!=null then
call UnitAddItem(NS[i],ti)
endif
set i2=i2+1
endloop
set i2=0
loop
exitwhen i2==6
set ti=UnitItemInSlot(Y4,i2)
if ti!=null then
call SetPlayerState(Player(i),PLAYER_STATE_RESOURCE_GOLD,GetPlayerState(Player(i),PLAYER_STATE_RESOURCE_GOLD)+H3(GetItemTypeId(ti)))
call F2(Player(i),"|cffffcc00No room, "+GetItemName(ti)+" refunded.|r")
call RemoveItem(ti)
endif
set i2=i2+1
endloop
else
call SetUnitPosition(NS[i],FS[i],GS[i])
endif
if GetLocalPlayer()==Player(i)then
call PanCameraTo(FS[i],GS[i])
call ClearSelection()
call SelectUnit(NS[i],true)
endif
endif
set i=i+1
endloop
set i=0
loop
exitwhen i==$C
if RT[i]!=null then
call FogModifierStop(RT[i])
endif
if ET[i] then
set JA=WP[i]
call ForForce(WP[i],function O2V)
endif
set i=i+1
endloop
call GroupClear(FA)
call GroupEnumUnitsInRect(FA,bj_mapInitialPlayableArea,null)
call ForGroup(FA,function OQV)
call O0V()
endfunction
function O3V takes nothing returns nothing
if IsPlayerInForce(GetOwningPlayer(GetEnumUnit()),HA)then
call PauseUnit(GetEnumUnit(),true)
call SetUnitInvulnerable(GetEnumUnit(),true)
else
call KillUnit(GetEnumUnit())
if GetEnumUnit()==NS[GetPlayerId(GetOwningPlayer(GetEnumUnit()))]then
set NS[GetPlayerId(GetOwningPlayer(GetEnumUnit()))]=null
endif
endif
endfunction
function O4V takes nothing returns nothing
if GetEnumPlayer()!=PA then
 
call SetPlayerAlliance(GetEnumPlayer(),PA,ALLIANCE_SHARED_VISION,false)
call SetPlayerAlliance(PA,GetEnumPlayer(),ALLIANCE_SHARED_VISION,false)
 
endif
endfunction
function O5V takes nothing returns boolean
return(IsUnitType(GetTriggerUnit(),UNIT_TYPE_HERO)and LA)!=null
endfunction
function O6V takes nothing returns nothing
local integer i=0
local integer i2=0
local integer i3=-1
local player p
loop
exitwhen i==$C
if IsPlayerInForce(GetOwningPlayer(GetTriggerUnit()),WP[i])then
set PA=GetOwningPlayer(GetTriggerUnit())
call ForForce(WP[i],function O4V)
call FogModifierStart(RT[i])
endif
set i=i+1
endloop
call SetUnitState(GetTriggerUnit(),UNIT_STATE_LIFE,.0)
call OUV()
loop
exitwhen i==$C
if XT[i]>0 then
set i2=i2+1
set i3=i
endif
set i=i+1
endloop
if i2==1 then
set OT[i3]=OT[i3]+1
if PR==$C then
set p=P2(WP[i3])
call DisplayTimedTextFromPlayer(GetLocalPlayer(),.0,.0,10.,ES[i3]+XS[GetPlayerId(p)]+" has won the round.")
set p=null
else
call DisplayTimedTextFromPlayer(GetLocalPlayer(),.0,.0,10.,ES[i3]+YQ[i3]+" Team has won the round.")
endif
if OT[i3]>=SR then
set HA=WP[i3]
call GroupClear(DA)
call GroupEnumUnitsInRect(DA,bj_mapInitialPlayableArea,null)
call ForGroup(DA,function O3V)
call PauseTimer(CA)
call LeaderboardDisplay(lb,false)
else
call OYV()
endif
endif
endfunction
function O7V takes nothing returns nothing
local unit u
set u=GetTriggerUnit()
call UnitResetCooldown(u)
call SetUnitState(u,UNIT_STATE_MANA,GetUnitState(u,UNIT_STATE_MAX_MANA))
endfunction
function O8V takes nothing returns nothing
local real x=GetUnitX(GetOrderTargetUnit())
local real y=GetUnitY(GetOrderTargetUnit())
call IssueImmediateOrderById(GetTriggerUnit(),$D0004)
call IssuePointOrderById(GetTriggerUnit(),GetIssuedOrderId(),x,y)
endfunction
function O9V takes nothing returns boolean
return(OrderId2String(GetIssuedOrderId())!="smart" and GetUnitPointValue(GetTriggerUnit())=='d' and(IsUnitType(GetOrderTargetUnit(),UNIT_TYPE_HERO)or IsUnitType(GetOrderTargetUnit(),UNIT_TYPE_STRUCTURE))and IsUnitEnemy(GetTriggerUnit(),GetOwningPlayer(GetOrderTargetUnit())))!=null
endfunction
function RVV takes nothing returns boolean
return GetSpellAbilityId()=='A02D'
endfunction
function REV takes nothing returns nothing
