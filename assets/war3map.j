function NPV takes nothing returns boolean
local integer d=T3()
local integer f
local real x
local real y
local real tx
local real ty
local real NQV
local real NSV
local real NTV
local real NUV
local real NWV
local real NYV
local unit R1
local group g
local boolean NZV
set x=GetUnitX(HJ[d])
set y=GetUnitY(HJ[d])
if CountUnitsInGroup(JJ[d])==0 then
call NHV(d)
return true
endif
if HJ[d]==null or GetUnitState(HJ[d],UNIT_STATE_LIFE)<.405 then
call ForGroup(JJ[d],function NMV)
call NHV(d)
return true
endif
set g=D1()
call C1(JJ[d])
call Q2(JJ[d],g)
loop
set R1=FirstOfGroup(g)
if R1!=null then
if NKV(R1) then
set f=K7(R1)
set tx=GetUnitX(R1)
set ty=GetUnitY(R1)
set NQV=Deg2Rad(GetUnitFacing(R1))
set NZV=false
if PJ[d] then
set NWV=U1(P1(tx,ty,KJ[d],LJ[d]))
if W1(NQV,NWV,.1) then
call NLV(R1)
call SetUnitFacing(R1,Rad2Deg(NWV))
call GroupRemoveUnit(JJ[d],R1)
set NZV=true
endif
endif
if KD[f]<5 then
set NZV=true
endif
if NZV==false then
set NSV=S1(P1(x,y,tx,ty))
set NTV=U1(NSV-1.57)
set NUV=U1(NSV+1.57)
set NYV=Q1(x,y,tx,ty)
if NYV<=900. then
if W1(NQV,NTV,1.17) then
if NYV>100. then
set SD[f]=SD[f]+(NTV-(NYV/ 1000.-.07)-NQV)
endif
endif
if W1(NQV,NUV,1.17) then
if NYV>100. then
set SD[f]=SD[f]+(NUV+(NYV/ 1000.-.07)-NQV)
endif
endif
else
call GroupRemoveUnit(JJ[d],R1)
call NLV(R1)
endif
endif
else
call GroupRemoveUnit(JJ[d],R1)
endif
else
exitwhen R1==null and CountUnitsInGroup(g)==0
endif
call GroupRemoveUnit(g,R1)
endloop
set R1=null
call F1(g)
set g=null
return false
endfunction
function N_V takes nothing returns nothing
local integer d
local integer e
