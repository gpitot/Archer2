loop
exitwhen i==6
call SetPlayerState(p,PLAYER_STATE_RESOURCE_GOLD,GetPlayerState(p,PLAYER_STATE_RESOURCE_GOLD)+H3(GetItemTypeId(UnitItemInSlot(NS[GetPlayerId(p)],i))))
call RemoveItem(UnitItemInSlot(NS[GetPlayerId(p)],i))
set i=i+1
endloop
call E3(p)
call SetPlayerState(p,PLAYER_STATE_RESOURCE_GOLD,0)
call GroupEnumUnitsOfPlayer(g,p,null)
call ForGroup(g,function OHV)
call F1(g)
call ForceEnumPlayers(f,Condition(function OCV))
call ForForce(f,function OFV)
call CreateFogModifierRect(p,FOG_OF_WAR_VISIBLE,bj_mapInitialPlayableArea,true,false)
set i=0
set i2=0
loop
exitwhen i==$C
if GetWidgetLife(IS[i])<.405 or IS[i]==null or Player(i)==GetOwningPlayer(u)then
set i2=0
