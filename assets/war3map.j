if(GetPlayerSlotState(Player(i))==PLAYER_SLOT_STATE_PLAYING and GetPlayerController(Player(i))==MAP_CONTROL_USER)then
call ForceAddPlayer(WP[a],Player(i))
set p=p+1
endif
set i=i+1
endloop
set a=a+1
endloop
endif
set i=0
loop
exitwhen i==$C
call I6(WP[i])
set i=i+1
endloop
set BX=PLAYER_COLOR_RED
set CX=0
call ForForce(WP[0],function R6)
