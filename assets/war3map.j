call MultiboardSetItemValue(X5,"|c003366CCPlayers divided into 4 teams|r")
call MultiboardReleaseItem(X5)
set X5=MultiboardGetItem(TR,5,0)
call MultiboardSetItemValue(X5,"|c003366CC-5team|r")
call MultiboardReleaseItem(X5)
set X5=MultiboardGetItem(TR,5,1)
call MultiboardSetItemValue(X5,"|c003366CCPlayers divided into 5 teams|r")
call MultiboardReleaseItem(X5)
set X5=MultiboardGetItem(TR,6,0)
call MultiboardSetItemValue(X5,"|c003366CC-6team|r")
call MultiboardReleaseItem(X5)
set X5=MultiboardGetItem(TR,6,1)
call MultiboardSetItemValue(X5,"|c003366CCPlayers divided into 6 teams|r")
call MultiboardReleaseItem(X5)
set X5=MultiboardGetItem(TR,7,0)
call MultiboardSetItemValue(X5,"|c003366CC-sg X|r")
call MultiboardReleaseItem(X5)
set X5=MultiboardGetItem(TR,7,1)
call MultiboardSetItemValue(X5,"|c003366CCToggle Starting Gold (Enter gold [1-1000] in place of X)|r")
call MultiboardReleaseItem(X5)
set X5=MultiboardGetItem(TR,8,0)
call MultiboardSetItemValue(X5,"|c003366CC-dm X|r")
call MultiboardReleaseItem(X5)
set X5=MultiboardGetItem(TR,8,1)
call MultiboardSetItemValue(X5,"|c003366CCToggle Deathmatch (Enter kills [10-100] in place of X)|r")
call MultiboardReleaseItem(X5)
set X5=MultiboardGetItem(TR,9,0)
call MultiboardSetItemValue(X5,"|c003366CC-rm|r")
call MultiboardReleaseItem(X5)
set X5=MultiboardGetItem(TR,9,1)
call MultiboardSetItemValue(X5,"|c003366CCToggle Round Mode (Enter win limit [5-30] in place of X)|r")
call MultiboardReleaseItem(X5)
set X5=MultiboardGetItem(TR,$A,0)
call MultiboardSetItemValue(X5,"|c003366CC-fm|r")
call MultiboardReleaseItem(X5)
set X5=MultiboardGetItem(TR,$A,1)
call MultiboardSetItemValue(X5,"|c003366CCToggle Fun Mode|r")
call MultiboardReleaseItem(X5)
set X5=MultiboardGetItem(TR,$B,0)
call MultiboardSetItemValue(X5,"|c003366CC-tl|r")
call MultiboardReleaseItem(X5)
set X5=MultiboardGetItem(TR,$B,1)
call MultiboardSetItemValue(X5,"|c003366CCToggle Target Lock|r")
call MultiboardReleaseItem(X5)
set X5=MultiboardGetItem(TR,$C,0)
call MultiboardSetItemValue(X5,"|c003366CC-sp|r")
call MultiboardReleaseItem(X5)
set X5=MultiboardGetItem(TR,$C,1)
call MultiboardSetItemValue(X5,"|c003366CCToggle Shuffle Players|r")
call MultiboardReleaseItem(X5)
set X5=MultiboardGetItem(TR,$D,0)
call MultiboardSetItemValue(X5,"|c00ff0000-done|r")
call MultiboardReleaseItem(X5)
set X5=MultiboardGetItem(TR,$D,1)
call MultiboardSetItemValue(X5,"|c00ff0000Start game with current settings|r")
call MultiboardReleaseItem(X5)
set X5=null
if IsPlayerInForce(GetLocalPlayer(),bj_FORCE_ALL_PLAYERS)then
call DisplayTextToPlayer(GetLocalPlayer(),.0,.0,"|cffffcc00Player 1, please take a few seconds to read game mode descriptions because their effects have been changed|r")
endif
call TriggerSleepAction(.01)
call MultiboardDisplay(TR,false)
if GetLocalPlayer()==Player(0)then
call MultiboardDisplay(TR,true)
call MultiboardMinimize(TR,false)
endif
endfunction
