if NV[UV]<1 then
call PauseTimer(IV[UV])
endif
else
set GV[HV[YV]]=GV[YV]
endif
set KV[LV]=YV
set LV=LV+1
call msgTimer("M3 Finish")
return false
endfunction
function P3 takes code Q3,integer S3,real A0 returns nothing
    call msgDebug("P3 Call")
