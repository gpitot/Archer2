function FUV takes nothing returns boolean
local integer LY=CW
local integer i=0
call DestroyEffect(SM[LY])
set SM[LY]=null
loop
exitwhen i>4
call RemoveUnit(WM[YM[LY]+i])
call DestroyLightning(TM[UM[LY]+i])
set WM[YM[LY]+i]=null
set TM[UM[LY]+i]=null
set i=i+1
endloop
return true
endfunction
