local boolean stop=false
local force f=CreateForce()
local player B6
set PR=t
loop
exitwhen i==$C
if(GetPlayerSlotState(Player(i))==PLAYER_SLOT_STATE_PLAYING and GetPlayerController(Player(i))==MAP_CONTROL_USER)then
set np=np+1
call ForceAddPlayer(f,Player(i))
endif
set i=i+1
