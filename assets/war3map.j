local integer d=S6(u)
local integer a
if d!=0 then
if u==UC[d]then
set a=S6(WC[d])
if a!=0 then
call U6(a)
endif
call U6(d)
endif
endif
set u=null
endfunction
function ROV takes nothing returns nothing
local unit u=GetTriggerUnit()
local integer a=S6(u)
local integer b
if a!=0 then
if u==UC[a]then
set b=S6(WC[a])
if b!=0 then
call U6(b)
endif
call U6(a)
elseif u==WC[a]then
set b=S6(UC[a])
if b!=0 then
call U6(b)
endif
call U6(a)
endif
endif
set u=null
endfunction
function RRV takes unit TY returns integer
local integer J5=J4(TY)
if TG[J5]!=0 then
if SG[J5]!=TY then
call TZ(TG[J5])
set SG[J5]=null
set TG[J5]=0
endif
endif
return TG[J5]
endfunction
function RIV takes unit TY,integer UY returns nothing
local integer J5=J4(TY)
if TG[J5]!=0 then
call TZ(TG[J5])
endif
set SG[J5]=TY
set TG[J5]=UY
set UG[UY]=J5
endfunction
function RAV takes integer LY returns nothing
local integer J5=UG[(LY)]
call TZ(LY)
set SG[J5]=null
set TG[J5]=0
endfunction
function RNV takes nothing returns integer
local integer d=SZ()
set WG[d]=null
set YG[d]=1
set ZG[d]=.0
set VH[d]=.0
set EH[d]=0
set XH[d]=0
return d
endfunction
function RBV takes nothing returns boolean
local integer d=T3()
local integer a=RNV()
local unit Y4
local real x=GetUnitX(WG[d])
local real y=GetUnitY(WG[d])
local real Y1=P1(x,y,ZG[d],VH[d])
if GetUnitState(WG[d],UNIT_STATE_LIFE)>.405 then
set Y4=CreateUnit(GetOwningPlayer(WG[d]),'H00I',x,y,Rad2Deg(Y1))
set WG[a]=WG[d]
call RIV(Y4,a)
call SetUnitPathing(Y4,false)
call SetUnitX(Y4,x)
call SetUnitY(Y4,y)
call UnitAddAbility(Y4,EH[d])
call SetUnitAbilityLevel(Y4,EH[d],XH[d])
call UnitApplyTimedLife(Y4,'BTLF',4.)
call IssuePointOrderById(Y4,$D00FA,ZG[d],VH[d])
call IssuePointOrderById(Y4,$D0264,ZG[d],VH[d])
call IssuePointOrderById(Y4,$D0250,ZG[d],VH[d])
call SetUnitAnimation(WG[d],"attack")
call QueueUnitAnimation(WG[d],"stand")
set Y4=null
endif
return true
endfunction
function RCV takes nothing returns nothing
local unit u=GetTriggerUnit()
local real x=GetLocationX(GetSpellTargetLoc())
local real y=GetLocationY(GetSpellTargetLoc())
local integer d
set d=RRV(u)
if A3(u,'I00N')>=1 or A3(u,'I00T')>=1 then
if d==0 then
set d=RNV()
call RIV(u,d)
set WG[d]=u
set YG[d]=1
else
set YG[d]=YG[d]+1
endif
if YG[d]>=$A then
set YG[d]=0
set ZG[d]=x
set VH[d]=y
set EH[d]=GetSpellAbilityId()
set XH[d]=GetUnitAbilityLevel(u,EH[d])
call O4(function RBV,d,.15)
endif
endif
set u=null
endfunction
function RDV takes nothing returns boolean
return(GetSpellAbilityId()=='A011' or GetSpellAbilityId()=='A017' or GetSpellAbilityId()=='A006' or GetSpellAbilityId()=='A022' or GetSpellAbilityId()=='A027' or GetSpellAbilityId()=='A028' or GetSpellAbilityId()=='A003' or GetSpellAbilityId()=='A021' or GetSpellAbilityId()=='A01J')and GetUnitTypeId(GetTriggerUnit())!='H00I'
endfunction
function RFV takes unit TY returns integer
local integer J5=J4(TY)
if NH[J5]!=0 then
if AH[J5]!=TY then
call PZ(NH[J5])
set AH[J5]=null
set NH[J5]=0
endif
endif
return NH[J5]
endfunction
function RGV takes unit TY,integer UY returns nothing
local integer J5=J4(TY)
if NH[J5]!=0 then
call PZ(NH[J5])
endif
set AH[J5]=TY
set NH[J5]=UY
set BH[UY]=J5
endfunction
function RHV takes nothing returns integer
local integer d=MZ()
set CH[d]=null
set DH[d]=1
set FH[d]=.0
set GH[d]=.0
set HH[d]=null
set JH[d]=null
return d
endfunction
function RJV takes nothing returns boolean
return IsUnitEnemy(GetFilterUnit(),GetOwningPlayer(QA))and(IsUnitVisible(GetFilterUnit(),GetOwningPlayer(QA))or not UnitHasBuffBJ(GetFilterUnit(),'BOwk'))and GetUnitState(GetFilterUnit(),UNIT_STATE_LIFE)>.405 and GetUnitAbilityLevel(GetFilterUnit(),'Avul')==0
endfunction
function RKV takes nothing returns nothing
call DestroyEffect(AddSpecialEffectTarget("Abilities\\Spells\\NightElf\\Starfall\\StarfallTarget.mdl",GetEnumUnit(),"origin"))
endfunction
function RLV takes nothing returns boolean
local unit Y4
local unit R1
local real x
local real y
local integer d=T3()
set QA=CH[d]
set Y4=CreateUnit(GetOwningPlayer(CH[d]),'h00A',FH[d],GH[d],.0)
call UnitApplyTimedLife(Y4,'BTLF',4.)
loop
set R1=FirstOfGroup(JH[d])
exitwhen R1==null
if(IsUnitVisible(R1,GetOwningPlayer(CH[d]))or not UnitHasBuffBJ(R1,'BOwk'))and GetUnitState(R1,UNIT_STATE_LIFE)>.405 then
call UnitDamageTarget(Y4,R1,150.,false,false,ATTACK_TYPE_CHAOS,DAMAGE_TYPE_UNIVERSAL,null)
endif
call GroupRemoveUnit(JH[d],R1)
endloop
set R1=null
call DestroyEffect(HH[d])
set HH[d]=null
set Y4=null
return true
endfunction
function RMV takes nothing returns nothing
local unit u=GetTriggerUnit()
local unit ds=GetEventDamageSource()
local real x=GetUnitX(u)
local real y=GetUnitY(u)
local unit R1
local integer d
local integer e=K7(ds)
if e!=0 then
set d=RFV(GD[e])
if A3(GD[e],'I00Q')>=1 or A3(GD[e],'I00T')>=1 then
if d==0 then
set d=RHV()
call RGV(GD[e],d)
set CH[d]=GD[e]
set DH[d]=1
set JH[d]=D1()
else
set DH[d]=DH[d]+1
endif
if DH[d]>=$A then
call GroupClear(JH[d])
set DH[d]=0
set FH[d]=x
set GH[d]=y
if HH[d]!=null then
call DestroyEffect(HH[d])
endif
set HH[d]=AddSpecialEffect("Abilities\\Spells\\NightElf\\Starfall\\StarfallCaster.mdl",x,y)
set QA=CH[d]
call GroupEnumUnitsInRange(JH[d],FH[d],GH[d],700,Condition(function RJV))
call ForGroup(JH[d],function RKV)
call O4(function RLV,d,.75)
endif
endif
endif
set u=null
set ds=null
endfunction
function RPV takes nothing returns boolean
return GetEventDamage()>0 and GetUnitTypeId(GetEventDamageSource())=='h00J'
endfunction
function RQV takes nothing returns nothing
local unit u=GetTriggerUnit()
local integer a=RRV(u)
if a!=0 then
call RAV(a)
call RemoveUnit(u)
endif
set u=null
endfunction
function RSV takes nothing returns boolean
return GetUnitTypeId(GetTriggerUnit())=='H00I'
endfunction
function RTV takes nothing returns nothing
