set b=b+"|c00FF0000/Fun Mode Off|r"
elseif HS[$A] and JS[$A]==false then
set JS[$A]=true
set b=b+"|c00FF0000/Fun Mode On|r"
elseif JS[$A] then
set b=b+"|c00FF0000/Fun Mode On|r"
endif
