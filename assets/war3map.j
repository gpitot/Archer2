function C6V takes nothing returns nothing
local unit u=GetTriggerUnit()
local real x=GetUnitX(u)
local real y=GetUnitY(u)
local real x2=GetUnitX(NS[GetPlayerId(GetOwningPlayer(u))])
local real y2=GetUnitY(NS[GetPlayerId(GetOwningPlayer(u))])
if GetUnitState(NS[GetPlayerId(GetOwningPlayer(u))],UNIT_STATE_LIFE)>.405 then
if GetUnitState(NS[GetPlayerId(GetOwningPlayer(u))],UNIT_STATE_LIFE)>GetUnitState(NS[GetPlayerId(GetOwningPlayer(u))],UNIT_STATE_MAX_LIFE)*.6 then
call DestroyEffect(AddSpecialEffect("Abilities\\Spells\\Items\\AIvi\\AIviTarget.mdl",x,y))
call DestroyEffect(AddSpecialEffect("Abilities\\Spells\\Items\\AIvi\\AIviTarget.mdl",x2,y2))
call SetUnitX(NS[GetPlayerId(GetOwningPlayer(u))],H1(x))
call SetUnitY(NS[GetPlayerId(GetOwningPlayer(u))],K1(y))
call ShowUnit(u,false)
if GetLocalPlayer()==GetOwningPlayer(u)then
call ClearSelection()
call SelectUnit(NS[GetPlayerId(GetOwningPlayer(u))],true)
endif
call UnitDamageTarget(NS[GetPlayerId(GetOwningPlayer(u))],NS[GetPlayerId(GetOwningPlayer(u))],GetUnitState(NS[GetPlayerId(GetOwningPlayer(u))],UNIT_STATE_MAX_LIFE)*.6,false,false,ATTACK_TYPE_CHAOS,DAMAGE_TYPE_UNIVERSAL,null)
else
call F2(GetOwningPlayer(u),"Not Enough Health")
call S5(u,1.)
call UnitRemoveAbility(u,'A01N')
call UnitAddAbility(u,'A01N')
endif
else
call F2(GetOwningPlayer(u),"Hero is not alive")
call S5(u,1.)
call UnitRemoveAbility(u,'A01N')
call UnitAddAbility(u,'A01N')
endif
endfunction
function C7V takes nothing returns boolean
return GetSpellAbilityId()=='A00R'
endfunction
function C8V takes nothing returns nothing
local unit h=NS[GetPlayerId(GetOwningPlayer(GetTriggerUnit()))]
local real x=GetUnitX(h)
local real y=GetUnitY(h)
if GetUnitState(h,UNIT_STATE_LIFE)>.405 then
if GetLocalPlayer()==GetOwningPlayer(h)then
call ClearSelection()
call PanCameraToTimed(x,y,.0)
call SelectUnit(h,true)
endif
else
call F2(GetOwningPlayer(GetTriggerUnit()),"Hero is not alive")
endif
call S5(GetTriggerUnit(),.01)
set h=null
endfunction
function C9V takes unit TY returns integer
local integer J5=J4(TY)
if LP[J5]!=0 then
if KP[J5]!=TY then
call QY(LP[J5])
set KP[J5]=null
set LP[J5]=0
endif
endif
return LP[J5]
endfunction
function DVV takes unit TY,integer UY returns nothing
local integer J5=J4(TY)
if LP[J5]!=0 then
call QY(LP[J5])
endif
set KP[J5]=TY
set LP[J5]=UY
set MP[UY]=J5
endfunction
function DEV takes integer LY returns nothing
local integer J5=MP[(LY)]
call QY(LY)
set KP[J5]=null
set LP[J5]=0
endfunction
function DOV takes nothing returns boolean
return GetSpellAbilityId()=='A02M'
endfunction
function DRV takes nothing returns boolean
local real x
local real y
local integer d=T3()
if IsUnitHidden(PP[d]) or GetUnitState(QP[d],UNIT_STATE_LIFE)<.405 then
call DEV(d)
return true
endif
if IsUnitVisible(QP[d],GetOwningPlayer(PP[d]))==false then
call UnitRemoveBuffs(PP[d],true,true)
call S5(PP[d],1.25)
call DEV(d)
return true
endif
set x=GetUnitX(QP[d])
set y=GetUnitY(QP[d])
call SetUnitFacing(PP[d],GetUnitFacing(QP[d]))
call SetUnitX(PP[d],x)
call SetUnitY(PP[d],y)
return false
endfunction
function DIV takes nothing returns nothing
local real x=GetUnitX(GetSpellTargetUnit())
local real y=GetUnitY(GetSpellTargetUnit())
local integer d
if C9V(GetTriggerUnit())==0 then
set d=PY()
set PP[d]=GetTriggerUnit()
call DVV(PP[d],d)
set QP[d]=GetSpellTargetUnit()
call SetUnitFacing(PP[d],GetUnitFacing(QP[d]))
call O4(function DRV,d,.03)
endif
call S5(GetTriggerUnit(),1.)
endfunction
function DAV takes nothing returns nothing
local unit u=GetOrderedUnit()
local integer d=C9V(u)
if d!=0 then
set PP[d]=null
endif
set u=null
endfunction
function DNV takes nothing returns boolean
return GetUnitTypeId(GetTriggerUnit())=='e009'
endfunction
function DBV takes nothing returns boolean
return GetUnitTypeId(GetTriggerUnit())=='e009'
endfunction
function DCV takes nothing returns nothing
local integer d
local unit u=GetTriggerUnit()
local unit h=NS[GetPlayerId(GetOwningPlayer(u))]
local real x
local real y
set d=CPV(u)
if GetEventDamage()>=1 then
call P6(u)
call UnitRemoveBuffs(u,true,true)
call KillUnit(CreateUnit(GetOwningPlayer(u),'e003',GetUnitX(u),GetUnitY(u),GetUnitFacing(u)))
call ShowUnit(u,false)
if GetUnitState(h,UNIT_STATE_LIFE)>.405 then
call UnitDamageTarget(GetEventDamageSource(),h,GetUnitState(h,UNIT_STATE_MAX_LIFE)*.6,false,false,ATTACK_TYPE_CHAOS,DAMAGE_TYPE_UNIVERSAL,null)
endif
if GetUnitState(h,UNIT_STATE_LIFE)>.405 then
set x=GetUnitX(h)
set y=GetUnitY(h)
if GetLocalPlayer()==GetOwningPlayer(GetTriggerUnit())then
call ClearSelection()
call PanCameraTo(x,y)
call SelectUnit(h,true)
endif
endif
endif
endfunction
function DDV takes nothing returns boolean
return(GetUnitTypeId(GetTriggerUnit())==EN or GetUnitTypeId(GetTriggerUnit())==XN)and GetItemTypeId(GetSoldItem())=='I01S'
endfunction
function DFV takes nothing returns nothing
local unit u=GetTriggerUnit()
local unit n
local real x
local real y
local real DGV
local real O3
local real V8
local integer DHV
local player p
local unit dum
local unit DJV
set x=GetUnitX(u)
set y=GetUnitY(u)
set DGV=GetUnitState(u,UNIT_STATE_LIFE)
set O3=GetUnitState(u,UNIT_STATE_MANA)
set V8=GetUnitFacing(u)
set p=GetOwningPlayer(u)
set DHV=GetUnitTypeId(u)
set DJV=GetBuyingUnit()
if DHV==EN then
set n=CreateUnit(p,XN,x,y,V8)
elseif DHV==XN then
set n=CreateUnit(p,EN,x,y,V8)
endif
call RemoveUnit(u)
call SetUnitState(n,UNIT_STATE_LIFE,DGV)
call SetUnitState(n,UNIT_STATE_MANA,O3)
call SetUnitPathing(n,false)
call ShowUnit(n,false)
call SetUnitX(n,x)
call SetUnitY(n,y)
call ShowUnit(n,true)
call SetUnitPathing(n,true)
if GetWidgetLife(NS[GetPlayerId(GetOwningPlayer(u))])>.405 then
call SetUnitInvulnerable(n,true)
endif
set IS[GetPlayerId(p)]=n
if RM then
call UnitRemoveAbility(n,'Aro1')
endif
if GetLocalPlayer()==GetOwningPlayer(DJV)then
call ClearSelection()
call SelectUnit(n,true)
endif
set u=null
set n=null
set p=null
endfunction
function DKV takes nothing returns boolean
return IsUnitEnemy(GetFilterUnit(),ON)and GetUnitPointValue(GetFilterUnit())=='d' and GetUnitState(GetFilterUnit(),UNIT_STATE_LIFE)>.407
endfunction
function DLV takes nothing returns nothing
local real x=GetUnitX(GetEnumUnit())
local real y=GetUnitY(GetEnumUnit())
if GetLocalPlayer()==ON then
call PingMinimap(x,y,3)
endif
endfunction
function DMV takes nothing returns boolean
return GetSpellAbilityId()=='A00H'
endfunction
function DPV takes nothing returns nothing
local group g
if GetUnitState(IS[GetPlayerId(GetOwningPlayer(GetTriggerUnit()))],UNIT_STATE_MANA)>=2. then
set g=D1()
set ON=GetOwningPlayer(GetTriggerUnit())
call SetUnitState(IS[GetPlayerId(GetOwningPlayer(GetTriggerUnit()))],UNIT_STATE_MANA,GetUnitState(IS[GetPlayerId(GetOwningPlayer(GetTriggerUnit()))],UNIT_STATE_MANA)-2)
call GroupEnumUnitsInRect(g,bj_mapInitialPlayableArea,Condition(function DKV))
call ForGroup(g,function DLV)
call F1(g)
set g=null
set ON=null
else
call IssueImmediateOrderById(GetTriggerUnit(),$D0004)
call F2(GetOwningPlayer(GetTriggerUnit()),"Not enough mana")
endif
endfunction
function DQV takes nothing returns nothing
call FlashQuestDialogButton()
call CreateQuestBJ(0,"Game Info","Fast paced battle between up to 12 players with 6 classes of archer to choose from.  Master each class' strengths and weaknesses to dominate your enemies.  Strategize the the attacks and destroy the enemy Ancient of Wars.","ReplaceableTextures\\WorldEditUI\\Editor-Ally-NoPriority.blp")
call CreateQuestBJ(0,"Player Commands","TRIGSTR_3385","ReplaceableTextures\\WorldEditUI\\Editor-Ally-NoPriority.blp")
call CreateQuestBJ(2,"Credits","TRIGSTR_4687","ReplaceableTextures\\WorldEditUI\\Editor-Ally-NoPriority.blp")
call CreateQuestBJ(2,"Host Options","TRIGSTR_3387","ReplaceableTextures\\WorldEditUI\\Editor-Ally-NoPriority.blp")
call CreateQuestBJ(2,"Ranks","TRIGSTR_4688","ReplaceableTextures\\WorldEditUI\\Editor-Ally-NoPriority.blp")
call TriggerSleepAction(30.)
call DisplayTextToForce(bj_FORCE_ALL_PLAYERS,"|cffffcc00For help click Info (F9) at the top left hand corner.|r")
call DestroyTrigger(GetTriggeringTrigger())
endfunction
function DTV takes nothing returns nothing
call FogMaskEnableOff()
call FogEnableOff()
call SetTerrainFogExBJ(0,1000000000.,1000000000.,0,'d','d','d')
endfunction
function DWV takes nothing returns nothing
local string s=SubString(GetEventPlayerChatString(),6,StringLength(GetEventPlayerChatString()))
local real r
if StringCase(s,false)=="overhead" then
if GetLocalPlayer()==GetTriggerPlayer()then
call SetCameraField(CAMERA_FIELD_ANGLE_OF_ATTACK,270.,.0)
call SetCameraField(CAMERA_FIELD_ROTATION,90.,.0)
call SetCameraField(CAMERA_FIELD_ROLL,.0,.0)
endif
set s=null
return
endif
set r=S2R(s)
if r>4000. then
set r=4000.
call DisplayTextToPlayer(GetTriggerPlayer(),.0,.0,"|cffffcc00Zoom ranges from 2000 to 4000, example: -zoom 3000|r")
elseif r<2000. then
set r=2000.
call DisplayTextToPlayer(GetTriggerPlayer(),.0,.0,"|cffffcc00Zoom ranges from 2000 to 4000, example: -zoom 3000|r")
endif
if GetLocalPlayer()==GetTriggerPlayer()then
call SetCameraField(CAMERA_FIELD_TARGET_DISTANCE,r,1.)
endif
endfunction
function DYV takes nothing returns nothing
call SetPlayerState(GetEnumPlayer(),PLAYER_STATE_RESOURCE_LUMBER,IN)
call SetPlayerState(GetEnumPlayer(),PLAYER_STATE_RESOURCE_FOOD_USED,RN)
endfunction
function DZV takes nothing returns nothing
set RN=RN+1
if RN==60 then
set IN=IN+1
set RN=0
endif
call ForForce(bj_FORCE_ALL_PLAYERS,function DYV)
endfunction
function showEverySymbol takes string text returns nothing
    local integer len = StringLength(text)
    local integer i = 0
    loop
        call msgDebug(SubString(text, i, i+1))
        set i = i + 1
        exitwhen i >= len
    endloop
endfunction
function D_V takes nothing returns nothing
local integer i=0
loop
exitwhen i>=12
call msgDebug("D_V " + (XS[i]+" (New)"))
if (i == 0) then
    //call showEverySymbol(XS[i])
endif
call SetPlayerName(Player(i),(XS[i]+" (New)"))
set i=i+1
endloop
endfunction
function D0V takes nothing returns nothing
set NT[1]=" (Beginner)"
set NT[2]=" (Novice)"
set NT[3]=" (Trainer)"
set NT[4]=" (Archer)"
set NT[5]=" (Marksman)"
set NT[6]=" (Ranger)"
set NT[7]=" (Hunter)"
set NT[8]=" (Assassin)"
set NT[9]=" (Master)"
set NT[$A]=" (Priestess)"
set NT[$B]=" (Angel)"
set NT[$C]=" (Goddess)"
set BT[1]=0
set BT[2]='d'
set BT[3]=$C8
set BT[4]=500
set BT[5]=$3E8
set BT[6]=$5DC
set BT[7]=$7D0
set CT[1]=$A
set CT[2]=30
set CT[3]=60
set CT[4]='d'
set CT[5]=$C8
set CT[6]=500
set CT[7]=$3E8
set CT[8]=$5DC
set CT[9]=$7D0
set CT[$A]=5000
set CT[$B]=$2710
set CT[$C]=$4E20
call DestroyTrigger(GetTriggeringTrigger())
endfunction
function D1V takes nothing returns nothing
call ClearTextMessagesBJ(TW(GetTriggerPlayer()))
call DisplayTimedTextToForce(TW(GetTriggerPlayer()),1.,"|cffffcc00Tip: Use Timed Text: -tt xx ; replace xx with a number.  Example: -tt 0.2|r")
endfunction
function D3V takes nothing returns nothing
call DisplayTextToForce(TW(GetTriggerPlayer()),"|cffffcc00Do not forget to save your stats by typing -save!|r")
endfunction
function D5V takes nothing returns nothing
local string s
local player p=GetTriggerPlayer()
call I8()
call V2V(HQ[GetPlayerId(p)],$A,7)
call V2V(GQ[GetPlayerId(p)],$A,7)
set s=V8V(p,5)
set s=VTV(s,3)
if GetLocalPlayer()==p then
call ClearTextMessages()
call DisplayTimedTextToPlayer(GetLocalPlayer(),.0,.0,60.,"|cffffcc00===This save code is generated by Kode made by Korolen===|r")
call DisplayTimedTextToPlayer(GetLocalPlayer(),.0,.0,60.,"|cffffcc00Save Successful, Your code is:|r")
call DisplayTimedTextToPlayer(GetLocalPlayer(),.0,.0,60.,s)
call DisplayTimedTextToPlayer(GetLocalPlayer(),.0,.0,60.,"Letters are in |cffffcc00Yellow|r")
call DisplayTimedTextToPlayer(GetLocalPlayer(),.0,.0,60.,"Numbers are in |c00FF0000Red|r")
call DisplayTimedTextToPlayer(GetLocalPlayer(),.0,.0,60.,"|cffffcc00To load this code next time, type |r"+"-load "+s)
call DisplayTimedTextToPlayer(GetLocalPlayer(),.0,.0,60.,"|cffffcc00========================================================|r")
endif
endfunction
function D6V takes nothing returns boolean
return SubString(GetEventPlayerChatString(),0,6)=="-load "
endfunction
function D7V takes nothing returns nothing
local boolean b=false
local boolean c=false
local integer i=$C
local integer h=7
local player p=GetTriggerPlayer()
local string s
local multiboarditem X5=null
if not V9V(GetTriggerPlayer(),5,SubString(GetEventPlayerChatString(),6,999))then
if GetLocalPlayer()==p then
call DisplayTextToPlayer(p,.0,.0,"|c00FF0000Invalid Code|r")
endif
return
endif
set GQ[GetPlayerId(GetTriggerPlayer())]=V4V($A,7)
set HQ[GetPlayerId(GetTriggerPlayer())]=V4V($A,7)
if GetLocalPlayer()==GetTriggerPlayer()then
call DisplayTextToPlayer(GetLocalPlayer(),0,0,"|cffffcc00Load Successful 
Kills: "+I2S(HQ[GetPlayerId(GetTriggerPlayer())])+"
Deaths: "+I2S(GQ[GetPlayerId(GetTriggerPlayer())]))
endif
set X5=MultiboardGetItem(LQ[GetPlayerId(GetTriggerPlayer())],6,1)
call MultiboardSetItemValue(X5,I2S(HQ[GetPlayerId(GetTriggerPlayer())]))
call MultiboardReleaseItem(X5)
set X5=MultiboardGetItem(LQ[GetPlayerId(GetTriggerPlayer())],7,1)
call MultiboardSetItemValue(X5,I2S(GQ[GetPlayerId(GetTriggerPlayer())]))
call MultiboardReleaseItem(X5)
loop
exitwhen i==0 or b
if HQ[GetPlayerId(p)]>=CT[i]then
set b=true
call msgDebug("D7V " + NT[i] + " " + XS[GetPlayerId(p)])
call SetPlayerName(p,XS[GetPlayerId(p)]+NT[i])
set s=ES[GetPlayerId(p)]+XS[GetPlayerId(p)]+"|r has loaded the rank|cffffcc00"+NT[i]+"|r"
if IsPlayerInForce(GetLocalPlayer(),bj_FORCE_ALL_PLAYERS)then
call DisplayTextToPlayer(GetLocalPlayer(),.0,.0,s)
endif
set X5=MultiboardGetItem(LQ[GetPlayerId(p)],1,1)
call MultiboardSetItemValue(X5,NT[i])
call MultiboardReleaseItem(X5)
set X5=null
endif
set i=i-1
endloop
loop
exitwhen h==0 or c
if HQ[GetPlayerId(p)]>=BT[h]then
set c=true
call B7(p,h)
endif
set h=h-1
endloop
set p=null
set s=null
endfunction
