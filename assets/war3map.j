call F1(g2)
set g2=null
endif
endif
set Y4=null
if A3(ds,'I007')>=1 then
set Y4=CreateUnit(GetOwningPlayer(ds),'h00A',x,y,.0)
call UnitApplyTimedLife(Y4,'BTLF',4.)
