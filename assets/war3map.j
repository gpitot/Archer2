function VXV takes integer VOV returns nothing
local integer i=0
local integer B6
local integer VRV
call SetRandomSeed(VOV)
loop
exitwhen i>=OO-1
set B6=GetRandomInt(i,OO-1)
set VRV=XO[B6]
set XO[B6]=XO[i]
set XO[i]=VRV
set i=i+1
endloop
endfunction
function VIV takes integer VOV returns nothing
local integer array VAV
local integer i=0
local integer VRV
call SetRandomSeed(VOV)
loop
exitwhen i>=OO-1
set VAV[i]=GetRandomInt(i,OO-1)
set i=i+1
endloop
set i=OO-2
loop
set VRV=XO[VAV[i]]
set XO[VAV[i]]=XO[i]
set XO[i]=VRV
exitwhen i<=0
set i=i-1
endloop
endfunction
function VNV takes string VBV returns integer
local string VCV="abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ1234567890_()"
local integer i=0
local integer j
local string c
local integer K8=0
loop
set c=SubString(VBV,i,i+1)
exitwhen c==null
set j=0
loop
exitwhen j>=StringLength(VCV)or SubString(VCV,j,j+1)==c
set j=j+1
endloop
if j>=26 then
set j=j-26
endif
set K8=((K8+$BCECE9)*$63A105F*ModuloInteger(j*j*K8+'{',50))
set i=i+1
endloop
return IAbsBJ(K8)
endfunction
function VDV takes player p,integer VFV returns nothing
local integer i=0
local integer j
local integer VGV
if p!=null then
set VGV=VNV(XS[GetPlayerId(p)])
else
set VGV=$3039
endif
loop
exitwhen OO>=VFV
set XO[OO]=0
set OO=OO+1
endloop
loop
exitwhen i>=ZX
call VXV(VGV)
set j=0
loop
exitwhen j>=OO
if XO[j]==0 then
set XO[j]=1
if XO[ModuloInteger(j+1,OO)]==1 then
set XO[ModuloInteger(j+1,OO)]=0
else
set XO[ModuloInteger(j+1,OO)]=1
endif
else
set XO[j]=0
endif
set j=j+1
endloop
call SetRandomSeed(VGV)
set VGV=GetRandomInt(0,$F4240)
set i=i+1
endloop
endfunction
function VHV takes player p,integer VFV returns nothing
local integer i=ZX-1
local integer j
local integer VGV
local integer array VJV
if p!=null then
set VGV=VNV(XS[GetPlayerId(p)])
else
set VGV=$3039
endif
loop
exitwhen OO>=VFV
set XO[OO]=0
set OO=OO+1
endloop
loop
set VJV[i]=VGV
call SetRandomSeed(VGV)
set VGV=GetRandomInt(0,$F4240)
exitwhen i<=0
set i=i-1
endloop
set i=0
loop
exitwhen i>=ZX
set j=OO-1
loop
exitwhen j<0
if XO[j]==1 then
set XO[j]=0
if XO[ModuloInteger(j+1,OO)]==1 then
set XO[ModuloInteger(j+1,OO)]=0
else
set XO[ModuloInteger(j+1,OO)]=1
endif
else
set XO[j]=1
endif
set j=j-1
endloop
call VIV(VJV[i])
set i=i+1
endloop
endfunction
function VKV takes nothing returns boolean
local integer i=0
loop
exitwhen i>=OO
if XO[i]==1 then
return false
endif
set i=i+1
endloop
return true
endfunction
function VLV takes integer VFV returns string
local string s=""
local integer D8
loop
exitwhen VFV<=0
set D8=VEV(StringLength(YX))
set s=SubString(YX,D8,D8+1)+s
set VFV=VFV-1
endloop
if not VKV()then
call BJDebugMsg("|cffff0000WARNING: Some bits have not been saved! Leftover bits: "+O8())
endif
return s
endfunction
