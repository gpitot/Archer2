if GetLocalPlayer()==Player(0)then
call CameraSetupApplyForceDurationWithZ(FO,15000.,0)
call ClearTextMessages()
endif
call DisplayTimedTextToPlayer(Player(0),.0,.0,10.,"|cffffcc00Terrain by Devrak|r")
call DisplayTimedTextToPlayer(Player(0),.0,.0,10.,"|cffffcc00Size: 7045 x 1122|r")
endif
endfunction
function E_V takes nothing returns boolean
