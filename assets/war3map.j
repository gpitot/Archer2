endfunction
function C1V takes nothing returns boolean
local integer d=T3()
local unit u
local real a
local real x
local real y
local real x2
local real y2
local real f
local real f2
local group g
local integer c='x'-(GetUnitAbilityLevel(FP[d],'A02F')*5)
local integer e
if IsUnitHidden(DP[d])then
return true
endif
if GetUnitAbilityLevel(DP[d],'A00S')==2 then
return true
endif
set VN=FP[d]
set x=GetUnitX(DP[d])
set y=GetUnitY(DP[d])
set ZA=D1()
call C1(GR)
call Q2(GR,ZA)
call ForGroup(ZA,function C_V)
set g=D1()
call Q2(ZA,g)
call F1(ZA)
set ZA=null
loop
set u=FirstOfGroup(g)
exitwhen u==null
set e=K7(u)
set x2=GetUnitX(u)
set y2=GetUnitY(u)
set f=GetUnitFacing(u)
set f2=f+180.
set a=Rad2Deg(P1(x2,y2,x,y))
if a<0 then
set a=a+360.
endif
if f>$B4 then
if a<=f and a>=f2-360. then
set SD[e]=SD[e]-Deg2Rad((KD[e]/ c))
else
set SD[e]=SD[e]+Deg2Rad((KD[e]/ c))
endif
else
if a>=f and a<=f2 then
set SD[e]=SD[e]+Deg2Rad((KD[e]/ c))
else
set SD[e]=SD[e]-Deg2Rad((KD[e]/ c))
endif
endif
call GroupRemoveUnit(g,u)
set e=0
endloop
call F1(g)
set g=null
set u=null
return false
endfunction
