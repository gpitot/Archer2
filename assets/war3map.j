local integer i=0
loop
exitwhen i==$C
if A3(NS[i],'rwiz')>=1 then
call X3(NS[i],R3(NS[i])+.25)
elseif A3(NS[i],'I00E')>=1 or A3(NS[i],'I00Y')>=1 then
