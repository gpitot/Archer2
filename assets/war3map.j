endloop
set u=null
call F1(g3)
set g3=null
set r=Rect(x-200.,y-200.,x+200.,y+200.)
call EnumDestructablesInRect(r,null,function H7)
call RemoveRect(r)
set r=null
endif
set BF[d]=false
call M7(d)
call UnitApplyTimedLife(HD[d],'BTLF',.1)
set u=null
set DW=true
return true
endif
endif
call GroupRemoveUnit(g,u)
endloop
set u=null
call F1(g)
set g=null
if IF[d] and AF[d]==false then
if GetUnitState(HD[d],UNIT_STATE_LIFE)>.405 then
set DF[d]=DF[d]+Y7
if DF[d]>=$FA then
set DF[d]=0
call E6(GD[d],x,y,PD[d]/ 5.)
call DestroyEffect(AddSpecialEffect(NF[d],x,y))
endif
endif
endif
if BF[d] then
set g=D1()
call GroupEnumUnitsInRange(g,x,y,600.,Condition(function D7))
call Q2(GR,g)
loop
set u=FirstOfGroup(g)
if u==HD[d]then
call GroupRemoveUnit(g,u)
set u=FirstOfGroup(g)
endif
exitwhen u==null
set x2=GetUnitX(u)
set y2=GetUnitY(u)
set W7=Q1(x,y,x2,y2)
if W7<=600. then
set a=P1(x2,y2,x,y)
if 400./ W7<=W7 then
set x2=H1(I2(x2,(KD[d]/(W7/ KD[d]*2.)),a))
set y2=K1(N2(y2,(KD[d]/(W7/ KD[d]*2.)),a))
endif
call SetUnitX(u,x2)
call SetUnitY(u,y2)
endif
call GroupRemoveUnit(g,u)
endloop
set u=null
call F1(g)
set g=null
endif
set u=null
set DW=false
return true
endfunction
