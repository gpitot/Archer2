function Math_Abs takes real r returns real
    if r<0 then
        return -r
    endif
    return r
endfunction

function FindOwner takes real x, real y returns integer
    local integer i = 0

    loop
        if (TreeXs[i] != 0 and TreeYs[i] != 0) then
            if Math_Abs(x - TreeXs[i]) < 100 and Math_Abs(y - TreeYs[i]) < 100 then
                return i
            endif
        endif
        set i = i + 1
        exitwhen i > 15
    endloop

    return i
endfunction
function BuildMain takes player p, real x, real y returns nothing
    local player neutral = Player(PLAYER_NEUTRAL_PASSIVE)
    local unit w=CreateUnit(p,'e002',x,y,.0)

    call msgDebug("Build Tree for Player " + I2S(GetPlayerId(p)))
    set TreeXs[GetPlayerId(p)] = x
    set TreeYs[GetPlayerId(p)] = y
    call IssueBuildOrder(w,"custom_e00A",x,y)
    set w = null
endfunction
function CastAbilityOnUnit takes unit target,integer AID,integer aLvL,string order returns nothing
    
    set bj_lastCreatedUnit=CreateUnit( Player(PLAYER_NEUTRAL_PASSIVE),'hzzz',GetUnitX(target)+90,GetUnitY(target),180)
    call UnitShareVision(bj_lastCreatedUnit, Player(PLAYER_NEUTRAL_PASSIVE),true)
    call UnitApplyTimedLife(bj_lastCreatedUnit,0x42544C46,1)
    call UnitAddAbility(bj_lastCreatedUnit,AID)
    call SetUnitAbilityLevel(bj_lastCreatedUnit,AID,aLvL)
    call IssueTargetOrder(bj_lastCreatedUnit,order,target)
endfunction

function RootWindrunner takes unit u returns nothing
    call CastAbilityOnUnit(u, 'A00V', 1, "entanglingroots")
endfunction
