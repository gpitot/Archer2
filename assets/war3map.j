function NRV takes nothing returns boolean
local integer d=T3()
local unit u
local real a
local real W7
local real x2
local real y2
local real f
local real f2
local group g
local integer e
set XJ[d]=GetUnitX(EJ[d])
set OJ[d]=GetUnitY(EJ[d])
if GetUnitState(EJ[d],UNIT_STATE_LIFE)<.405 then
call NXV(d)
set u=null
return true
endif
set g=D1()
call Q2(GR,g)
loop
set u=FirstOfGroup(g)
exitwhen u==null
set e=K7(u)
set x2=GetUnitX(u)
set y2=GetUnitY(u)
set f=GetUnitFacing(u)
set f2=f+180.
set W7=Q1(XJ[d],OJ[d],x2,y2)
if W7<=RJ[d]and NOV(u) then
set a=Rad2Deg(P1(x2,y2,XJ[d],OJ[d]))
if a<0 then
set a=a+360.
endif
if f>180. then
if a<=f and a>=f2-360. then
set SD[e]=SD[e]-AJ[d]*(KD[e]/ 660.)
else
set SD[e]=SD[e]+AJ[d]*(KD[e]/ 660.)
endif
else
if a>=f and a<=f2 then
set SD[e]=SD[e]+AJ[d]*(KD[e]/ 660.)
else
set SD[e]=SD[e]-AJ[d]*(KD[e]/ 660.)
endif
endif
endif
call GroupRemoveUnit(g,u)
set e=0
endloop
call F1(g)
set g=null
set u=null
return false
endfunction
function NIV takes nothing returns nothing
local integer d=KZ()
local integer s
local unit u=GetTriggerUnit()
local location l=GetSpellTargetLoc()
set AJ[d]=1
set IJ[d]=D1()
set XJ[d]=GetLocationX(l)
set OJ[d]=GetLocationY(l)
set EJ[d]=CreateUnit(GetOwningPlayer(u),'h00L',XJ[d],OJ[d],.0)
call UnitApplyTimedLife(EJ[d],'BTLF',20.+(5.*GetUnitAbilityLevel(GetTriggerUnit(),GetSpellAbilityId())))
set RJ[d]=($C8+('d'*GetUnitAbilityLevel(u,'A01W')))
set s=RRV(u)
if s!=0 then
set YG[s]=YG[s]+1
if YG[s]>=$A then
set YG[s]=0
set AJ[d]=2
endif
endif
call O4(function NRV,d,.03)
call RemoveLocation(l)
set u=null
set l=null
endfunction
