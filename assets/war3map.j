call TriggerEvaluate(AV[UV])
set WV=0
loop
exitwhen WV==TV
set WV=WV+1
if SV[WV]then
set CV[MV[WV]]=TriggerAddCondition(AV[UV],DV[MV[WV]])
else
call TriggerRemoveCondition(AV[UV],PV[WV])
call DestroyBoolExpr(QV[WV])
