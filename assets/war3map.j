function E3V takes nothing returns boolean
return SubString(GetEventPlayerChatString(),0,1)=="-"
endfunction
function E4V takes nothing returns nothing
local string a=GetEventPlayerChatString()
local string b
local string c
local integer LM=StringLength(a)
local integer E5V=1
local integer CL=2
local integer i=1
local integer h=1
local integer j
local integer k
local integer JR
local string dmc
local integer GM
local boolean ii=true
local integer E6V
loop
exitwhen i==$D
set HS[i]=false
set i=i+1
endloop
if LM>30 then
if(IsPlayerInForce(GetLocalPlayer(),bj_FORCE_ALL_PLAYERS))then
call DisplayTextToPlayer(GetLocalPlayer(),.0,.0,"|c00FF0000ERROR: Game mode string too long|r")
endif
endif
loop
exitwhen E5V>LM
set CL=E5V+1
loop
exitwhen CL>LM
set b=StringCase(SubString(GetEventPlayerChatString(),E5V,CL),true)
set h=1
loop
exitwhen h==$D
if b==KS[h]then
set HS[h]=true
if h==7 or h==8 or h==9 then
set k=CL
set j=CL+1
set ii=true
loop
exitwhen j>LM or ii==false
set c=StringCase(SubString(GetEventPlayerChatString(),j,j+1),true)
if c==null or c==" " or c=="0" or c=="1" or c=="2" or c=="3" or c=="4" or c=="5" or c=="6" or c=="7" or c=="8" or c=="9" then
set j=j+1
else
set ii=false
endif
endloop
if h==7 then
set bg=S2I(SubString(a,k,j))
elseif h==8 then
set E6V=S2I(SubString(a,k,j))
set KR=E6V
elseif h==9 then
set SR=S2I(SubString(a,k,j))
endif
endif
endif
set h=h+1
endloop
set CL=CL+1
endloop
set E5V=E5V+1
endloop
set i=1
set JR=0
loop
exitwhen i==7
if HS[i] then
set GM=i
set JR=JR+1
endif
set i=i+1
endloop
if JR==0 then
set i=1
loop
exitwhen i==7
if JS[i] then
set GM=i
endif
set i=i+1
endloop
endif
if JR>1 then
call DisplayTimedTextFromPlayer(GetLocalPlayer(),.0,.0,10.,"|c00FF0000ERROR: More than one main game mode|r")
else
set i=1
loop
exitwhen i==7
set JS[i]=false
set i=i+1
endloop
set JS[GM]=true
set b="|c00FF0000Current Game Selection: "+LS[GM]+"|r"
if HS[7] and(bg<1 or bg>$3E8)then
set JS[7]=false
set b=b+"|c00FF0000/Starting Gold Off |r"
elseif HS[7] then
