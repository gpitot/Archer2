function KY takes nothing returns integer
local integer LY=AN
if(LY!=0)then
set AN=BN[LY]
else
set NN=NN+1
set LY=NN
endif
if(LY>$7FE)then
call DisplayTimedTextToPlayer(GetLocalPlayer(),0,0,1000.,"Unable to allocate id for an object of type: Limit")
return 0
endif
set DN[LY]=(LY-1)*4
set HN[LY]=(LY-1)*4
set BN[LY]=-1
return LY
endfunction
function MY takes integer LY returns nothing
if LY==null then
call DisplayTimedTextToPlayer(GetLocalPlayer(),0,0,1000.,"Attempt to destroy a null struct of type: Limit")
return
elseif(BN[LY]!=-1)then
call DisplayTimedTextToPlayer(GetLocalPlayer(),0,0,1000.,"Double free of type: Limit")
return
endif
set BN[LY]=AN
set AN=LY
endfunction
