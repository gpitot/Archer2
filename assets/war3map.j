loop
exitwhen i==3
set ar=180.-(KD[d]*4.)
set V8=GetUnitFacing(a)
set la=V8-ar
set ha=V8+ar
set Y1=GetRandomReal(la,ha)
set cx=x
set cy=y
set tx=I2(x,200.,Deg2Rad(Y1))
set ty=N2(y,200.,Deg2Rad(Y1))
call U7('h00N',u,1,cx,cy,tx,ty,.03,60.,KD[d],33.,.3,400.,0,null,null)
set i=i+1
endloop
endif
call GroupRemoveUnit(g3,a)
