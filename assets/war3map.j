set N6=np/ t
set tb=np-(N6*t)
set i=0
loop
exitwhen i==t
set WP[i]=CreateForce()
set TP[i]=N6
set i=i+1
endloop
set i=0
loop
exitwhen tb==0
set TP[i]=TP[i]+1
set tb=tb-1
set i=i+1
endloop
set i=0
set a=0
if SP then
loop
exitwhen a==t
set p=0
loop
exitwhen p==TP[a]or Y2(f)==0
set B6=F3(f)
call ForceAddPlayer(WP[a],B6)
set p=p+1
call ForceRemovePlayer(f,B6)
endloop
set a=a+1
