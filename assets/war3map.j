endfunction
function E0V takes nothing returns nothing
call DisableTrigger(ST)
call DisableTrigger(YI)
if GetLocalPlayer()==Player(0)then
call ResetToGameCamera(.0)
call SetCameraField(CAMERA_FIELD_TARGET_DISTANCE,2000.,1.)
endif
if WI==1 then
set YR=GetRectMaxX(NO)
set ZR=GetRectMaxY(NO)
set VI=GetRectMinX(NO)
set EI=GetRectMinY(NO)
call DisplayTimedTextToPlayer(GetLocalPlayer(),.0,.0,10.,"|cffffcc00Terrain 1|r")
elseif WI==2 then
set YR=GetRectMaxX(BO)
set ZR=GetRectMaxY(BO)
set VI=GetRectMinX(BO)
set EI=GetRectMinY(BO)
call DisplayTimedTextToPlayer(GetLocalPlayer(),.0,.0,10.,"|cffffcc00Terrain 2|r")
endif
call RemoveUnit(TC)
set TC=null
call TriggerExecute(TA)
call DisplayTimedTextFromPlayer(GetLocalPlayer(),.0,.0,100.,"|c00FF0000Current Game Selection: Free For All|r")
call DisplayTimedTextFromPlayer(GetLocalPlayer(),.0,.0,100.,"|c00FF0000Host has 30 seconds to pick game mode|r")
call EnableTrigger(MS)
call EnableTrigger(VA)
call TimerStart(ZI,300.,false,null)
call TriggerExecute(RS)
call FogEnable(true)
endfunction
