call DisplayTimedTextToPlayer(GetOwningPlayer(u),.0,.0,WQ[GetPlayerId(GetOwningPlayer(u))],"|cffffcc00Double Shot Count: "+I2S(YG[d])+"|r")
endif
set u=null
