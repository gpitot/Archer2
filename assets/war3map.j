set vfai_Rest7=false
else
set vfai_c7h=vfai_n7s-4
endif 
if vfai_Rest7 then
set vfai_n8s=vfai_n7s-2
set vfai_HiHi=IsAB(vfai_n8s,vfai_mduss7)
set vfai_c9h=vfai_n7s-4
set vfai_c0h=vfai_n7s-3
