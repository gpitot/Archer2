function R2V takes nothing returns nothing
local integer d=IT[GetPlayerId(GetTriggerPlayer())]
local string ss=SubString(GetEventPlayerChatString(),7,$A)
local integer R3V
local item a
local integer i=0
local integer c=0
local boolean b=false
if ss=="a" or ss=="all" then
loop
exitwhen i==6
set c=0
set b=false
set a=UnitItemInSlot(NS[GetPlayerId(GetTriggerPlayer())],i)
if a!=null then
loop
exitwhen c==$C or b
if PH[QH[d]+c]==0 then
set PH[QH[d]+c]=GetItemTypeId(a)
set SH[TH[d]+c]=GetItemCharges(a)
call RemoveItem(a)
set b=true
endif
set c=c+1
endloop
endif
set i=i+1
endloop
else
set R3V=S2I(SubString(GetEventPlayerChatString(),7,8))-1
set a=UnitItemInSlot(NS[GetPlayerId(GetTriggerPlayer())],R3V)
if a!=null then
loop
exitwhen b or i==$C
if PH[QH[d]+i]==0 then
set PH[QH[d]+i]=GetItemTypeId(a)
set SH[TH[d]+i]=GetItemCharges(a)
set b=true
endif
set i=i+1
endloop
if b then
call DisplayTimedTextToPlayer(GetTriggerPlayer(),.0,.0,WQ[GetPlayerId(GetTriggerPlayer())],"|cffffcc00Item stored|r")
call RemoveItem(a)
else
call DisplayTimedTextToPlayer(GetTriggerPlayer(),.0,.0,WQ[GetPlayerId(GetTriggerPlayer())],"|cffffcc00Vault is full|r")
endif
else
call DisplayTimedTextToPlayer(GetTriggerPlayer(),.0,.0,WQ[GetPlayerId(GetTriggerPlayer())],"|cffffcc00Invalid Item|r")
endif
endif
set a=null
set b=false
endfunction
