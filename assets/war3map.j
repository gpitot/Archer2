elseif HS[$C] and JS[$C]==false then
set JS[$C]=true
set b=b+"|c00FF0000/Shuffle Players|r"
elseif JS[$C] then
set b=b+"|c00FF0000/Shuffle Players|r"
endif
call ClearTextMessages()
call DisplayTimedTextFromPlayer(GetLocalPlayer(),.0,.0,'d',b)
if TR!=null then
call MultiboardSetTitleText(TR,b)
endif
endif
endfunction
function E7V takes nothing returns nothing
local integer GM=0
local string b=null
local integer i=0
local integer pc=0

call msgTimer("E7V Start")
call DisableTrigger(GetTriggeringTrigger())
call DisableTrigger(MS)
if JS[1] then
set pc=$C
set GM=1
elseif JS[2] then
set pc=2
set GM=2
elseif JS[3] then
set pc=3
set GM=3
elseif JS[4] then
set pc=4
set GM=4
elseif JS[5] then
set pc=5
set GM=5
elseif JS[6] then
set pc=6
set GM=6
endif
if JS[$C] then
set SP=true
endif
call A6(pc)
set b="|c00FF0000Host has selected the game mode: "+LS[GM]+"|r"
set NI="|c00FF0000-="+KS[GM]
if JS[7] then
set b=b+"|c00FF0000/Starting Gold "+I2S(bg)+"|r"
set NI=NI+"/SG "+I2S(bg)
loop
exitwhen i==$C
call SetPlayerState(Player(i),PLAYER_STATE_RESOURCE_GOLD,bg)
set i=i+1
endloop
endif
if JS[8] then
call EnableTrigger(BI)
set DM=true
set b=b+"|c00FF0000/Deathmatch "+I2S(KR)+"|r"
set NI=NI+"/DM "+I2S(KR)
set DT=5
call DisableTrigger(VT)
endif
if JS[9] then
set RM=true
call DisableTrigger(VT)
call DisableTrigger(KI)
set b=b+"|c00FF0000/Round Mode"+I2S(SR)+"|r"
set NI=NI+"/RM "+I2S(SR)
endif
if JS[$A] then
call EnableTrigger(FM)
call DisableTrigger(VT)
set b=b+"|c00FF0000/Fun Mode|r"
set NI=NI+"/FM"
endif
if JS[$B] then
call EnableTrigger(TL)
set b=b+"|c00FF0000/Disable Target Lock|r"
set NI=NI+"/DTL"
endif
if JS[$C] then
set b=b+"|c00FF0000/Shuffle Players|r"
set NI=NI+"/SP"
endif
set NI=NI+"=-|r"
call DisplayTimedTextFromPlayer(GetLocalPlayer(),.0,.0,10.,b)
call DestroyMultiboard(TR)
set TR=null
call TriggerExecute(MI)
call TriggerExecute(GI)
call TriggerExecute(FI)
call TriggerExecute(HI)
call EnableTrigger(DI)
if IsPlayerInForce(GetLocalPlayer(),bj_FORCE_ALL_PLAYERS)then
call SetCineFilterTexture("ReplaceableTextures\\CameraMasks\\Black_mask.blp")
call SetCineFilterBlendMode(BLEND_MODE_BLEND)
call SetCineFilterTexMapFlags(TEXMAP_FLAG_NONE)
call SetCineFilterStartUV(0,0,1,1)
call SetCineFilterEndUV(0,0,1,1)
call SetCineFilterStartColor($FF,$FF,$FF,$FF)
call SetCineFilterEndColor($FF,$FF,$FF,0)
call SetCineFilterDuration(.0)
call DisplayCineFilter(true)
endif
call DisplayTimedTextFromPlayer(GetLocalPlayer(),.0,.0,10.,"|cffffcc00You now have 45 seconds to load|r")
call PauseTimer(ZI)
call DestroyTimer(ZI)
set ZI=null
call msgTimer("E7V Finish")
endfunction
