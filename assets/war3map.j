function IOV takes nothing returns boolean
return(GetUnitPointValue(GetTriggerUnit())=='d' and IsUnitType(GetTriggerUnit(),UNIT_TYPE_HERO))!=null
endfunction
function IRV takes nothing returns nothing
local integer i=1
local integer c=0
local item S7=null
local multiboarditem X5=null
call TriggerSleepAction(.01)
if GetTriggerUnit()==null or GetUnitState(GetTriggerUnit(),UNIT_STATE_LIFE)<.405 then
return
endif
loop
exitwhen c==6
set S7=UnitItemInSlot(GetTriggerUnit(),c)
set i=1
loop
exitwhen i==36
if GetItemTypeId(S7)==IQ[i]then
if c==0 then
set X5=MultiboardGetItem(LQ[GetPlayerId(GetOwningPlayer(GetTriggerUnit()))],$A,1)
call MultiboardSetItemIcon(X5,ZQ[i])
call MultiboardReleaseItem(X5)
elseif c==1 then
set X5=MultiboardGetItem(LQ[GetPlayerId(GetOwningPlayer(GetTriggerUnit()))],$A,2)
call MultiboardSetItemIcon(X5,ZQ[i])
call MultiboardReleaseItem(X5)
elseif c==2 then
set X5=MultiboardGetItem(LQ[GetPlayerId(GetOwningPlayer(GetTriggerUnit()))],$B,1)
call MultiboardSetItemIcon(X5,ZQ[i])
call MultiboardReleaseItem(X5)
elseif c==3 then
set X5=MultiboardGetItem(LQ[GetPlayerId(GetOwningPlayer(GetTriggerUnit()))],$B,2)
call MultiboardSetItemIcon(X5,ZQ[i])
call MultiboardReleaseItem(X5)
elseif c==4 then
set X5=MultiboardGetItem(LQ[GetPlayerId(GetOwningPlayer(GetTriggerUnit()))],$C,1)
call MultiboardSetItemIcon(X5,ZQ[i])
call MultiboardReleaseItem(X5)
elseif c==5 then
set X5=MultiboardGetItem(LQ[GetPlayerId(GetOwningPlayer(GetTriggerUnit()))],$C,2)
call MultiboardSetItemIcon(X5,ZQ[i])
call MultiboardReleaseItem(X5)
endif
endif
set i=i+1
endloop
set c=c+1
endloop
set X5=null
set S7=null
endfunction
function IIV takes nothing returns boolean
return GetPlayerSlotState(GetFilterPlayer())==PLAYER_SLOT_STATE_PLAYING and GetPlayerController(GetFilterPlayer())==MAP_CONTROL_USER and IsPlayerInForce(GetFilterPlayer(),bj_FORCE_ALL_PLAYERS)
endfunction
function IAV takes nothing returns nothing
set JR=JR+1
endfunction
function INV takes nothing returns nothing
local multiboarditem X5=null
local string s
set CQ[GetPlayerId(GetEnumPlayer())]=SA
set X5=MultiboardGetItem(UR,SA,0)
call MultiboardSetItemValue(X5,(ES[GetPlayerId(GetEnumPlayer())]+(XS[GetPlayerId(GetEnumPlayer())]+"|r")))
call MultiboardReleaseItem(X5)
set X5=MultiboardGetItem(UR,SA,1)
call MultiboardSetItemValue(X5,I2S(AQ[GetPlayerId(GetEnumPlayer())]))
call MultiboardReleaseItem(X5)
set X5=MultiboardGetItem(UR,SA,2)
call MultiboardSetItemValue(X5,I2S(EQ[GetPlayerId(GetEnumPlayer())]))
call MultiboardReleaseItem(X5)
set X5=null
set s="|cffffcc00"+NI+"|r |c0000FF00"+I2S(AQ[GetPlayerId(GetEnumPlayer())])+"|r|cffffcc00/|r|c00FF0000"+I2S(EQ[GetPlayerId(GetEnumPlayer())])+"|r"
if GetLocalPlayer()==GetEnumPlayer()then
call MultiboardSetTitleText(UR,s)
endif
set SA=SA+1
set s=null
endfunction
function IBV takes nothing returns nothing
local integer c
local integer i
local force f=CreateForce()
local multiboarditem X5=null
set JR=0
set f=WW(Condition(function IIV))
call ForForce(f,function IAV)
set c=JR
set UR=CreateMultiboard()
call MultiboardSetColumnCount(UR,3)
call MultiboardSetRowCount(UR,c+4)
call MultiboardSetTitleText(UR,"|cffffcc00Archer Wars|r |c0000FF000|r|cffffcc00/|r|c00FF00000|r")
set X5=MultiboardGetItem(UR,0,0)
call MultiboardSetItemValue(X5,"|cffffcc00Players|r")
call MultiboardReleaseItem(X5)
set X5=MultiboardGetItem(UR,0,1)
call MultiboardSetItemValue(X5,"|cffffcc00Kills|r")
call MultiboardReleaseItem(X5)
set X5=MultiboardGetItem(UR,0,2)
call MultiboardSetItemValue(X5,"|cffffcc00Deaths|r")
call MultiboardReleaseItem(X5)
set i=0
loop
exitwhen i>c+1
set X5=MultiboardGetItem(UR,i,0)
call MultiboardSetItemStyle(X5,true,false)
call MultiboardSetItemWidth(X5,.09)
call MultiboardReleaseItem(X5)
set X5=MultiboardGetItem(UR,i,1)
call MultiboardSetItemStyle(X5,true,false)
call MultiboardSetItemWidth(X5,.04)
call MultiboardReleaseItem(X5)
set X5=MultiboardGetItem(UR,i,2)
call MultiboardSetItemStyle(X5,true,false)
call MultiboardSetItemWidth(X5,.04)
call MultiboardReleaseItem(X5)
set i=i+1
endloop
set X5=MultiboardGetItem(UR,c+2,0)
call MultiboardSetItemStyle(X5,true,false)
call MultiboardSetItemWidth(X5,.19)
call MultiboardSetItemValue(X5,"|c0033CCFFPush Right Arrow for Stats|r")
call MultiboardReleaseItem(X5)
set X5=MultiboardGetItem(UR,c+2,1)
call MultiboardSetItemStyle(X5,true,false)
call MultiboardSetItemWidth(X5,.0)
call MultiboardReleaseItem(X5)
set X5=MultiboardGetItem(UR,c+2,2)
call MultiboardSetItemStyle(X5,true,false)
call MultiboardSetItemWidth(X5,.0)
call MultiboardReleaseItem(X5)
set X5=MultiboardGetItem(UR,c+3,0)
call MultiboardSetItemStyle(X5,true,false)
call MultiboardSetItemWidth(X5,.19)
call MultiboardSetItemValue(X5,"|c0033CCFFPush Down Arrow for Team|r")
call MultiboardReleaseItem(X5)
set X5=MultiboardGetItem(UR,c+3,1)
call MultiboardSetItemStyle(X5,true,false)
call MultiboardSetItemWidth(X5,.0)
call MultiboardReleaseItem(X5)
set X5=MultiboardGetItem(UR,c+3,2)
call MultiboardSetItemStyle(X5,true,false)
call MultiboardSetItemWidth(X5,.0)
call MultiboardReleaseItem(X5)
set SA=1
call ForForce(f,function INV)
call DestroyForce(f)
set i=0
loop
exitwhen i==$C
set KQ[i]=UR
if LQ[i]!=null then
call MultiboardDisplay(LQ[i],false)
endif
set i=i+1
endloop
call MultiboardDisplay(UR,true)
set f=null
set X5=null
endfunction
