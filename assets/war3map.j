call SetPlayerState(GetOwningPlayer(GetKillingUnit()),PLAYER_STATE_RESOURCE_GOLD,GetPlayerState(GetOwningPlayer(GetKillingUnit()),PLAYER_STATE_RESOURCE_GOLD)+20)
endif
call DisplayTimedTextFromPlayer(GetLocalPlayer(),.0,.0,WQ[GetPlayerId(GetLocalPlayer())],s2)
