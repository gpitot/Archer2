if I0>=1 then
set VF[d]=VF[d]+((Y7/ 80.)*I0)
if VF[d]<200. then
set PD[d]=PD[d]+((Y7/ 80)*I0)
endif
endif
set LD[d]=LD[d]+Y7
set WD[d]=x
set YD[d]=y
if GetUnitState(HD[d],UNIT_STATE_LIFE)<.405 then
set BF[d]=false
call M7(d)
set DW=true
return true
endif
if LD[d]>=MD[d]then
if GetUnitTypeId(HD[d])=='h00N' then
    call GroundExpFX(x, y)
set g3=D1()
