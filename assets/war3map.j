function IGV takes nothing returns nothing
local integer i=0
local boolean b=false
loop
exitwhen i==$C or b
if KQ[GetPlayerId(GetTriggerPlayer())]==LQ[i]then
if GetLocalPlayer()==GetTriggerPlayer()then
call MultiboardDisplay(LQ[i],false)
call MultiboardDisplay(UR,true)
endif
set KQ[GetPlayerId(GetTriggerPlayer())]=UR
set b=true
endif
set i=i+1
endloop
endfunction
function IHV takes nothing returns nothing
if KQ[GetPlayerId(GetTriggerPlayer())]==UR or KQ[GetPlayerId(GetTriggerPlayer())]==WR then
if GetLocalPlayer()==GetTriggerPlayer()then
call MultiboardDisplay(UR,false)
call MultiboardDisplay(LQ[GetPlayerId(GetTriggerPlayer())],true)
endif
set KQ[GetPlayerId(GetTriggerPlayer())]=LQ[GetPlayerId(GetTriggerPlayer())]
endif
endfunction
function IJV takes nothing returns nothing
local integer i=0
local integer s=0
local integer s2=0
local boolean b=false
if KQ[GetPlayerId(GetTriggerPlayer())]!=UR and KQ[GetPlayerId(GetTriggerPlayer())]!=WR then
loop
exitwhen i==$C or b
if KQ[GetPlayerId(GetTriggerPlayer())]==LQ[i]then
set s=i
set b=true
endif
set i=i+1
endloop
set b=false
set s2=s
loop
exitwhen b
set s2=s2+1
if s2==$C then
set s2=0
endif
if LQ[s2]!=null then
set b=true
if GetLocalPlayer()==GetTriggerPlayer()then
call MultiboardDisplay(LQ[s],false)
call MultiboardDisplay(LQ[s2],true)
endif
set KQ[GetPlayerId(GetTriggerPlayer())]=LQ[s2]
endif
endloop
else
if JS[1]==false then
if GetLocalPlayer()==GetTriggerPlayer()then
call MultiboardDisplay(UR,false)
call MultiboardDisplay(WR,true)
endif
set KQ[GetPlayerId(GetTriggerPlayer())]=WR
else
call DisplayTimedTextToPlayer(GetTriggerPlayer(),.0,.0,WQ[GetPlayerId(GetTriggerPlayer())],"|cffffcc00Team Board not available in FFA|r")
endif
endif
endfunction
function IKV takes nothing returns nothing
local integer i=0
local integer s=0
local integer s2=0
local boolean b=false
if KQ[GetPlayerId(GetTriggerPlayer())]!=UR then
if KQ[GetPlayerId(GetTriggerPlayer())]==WR then
if GetLocalPlayer()==GetTriggerPlayer()then
call MultiboardDisplay(WR,false)
call MultiboardDisplay(UR,true)
endif
set KQ[GetPlayerId(GetTriggerPlayer())]=UR
else
loop
exitwhen i==$C or b
if KQ[GetPlayerId(GetTriggerPlayer())]==LQ[i]then
set s=i
set b=true
endif
set i=i+1
endloop
set b=false
set s2=s
loop
exitwhen b
set s2=s2-1
if s2==-1 then
set s2=$B
endif
if LQ[s2]!=null then
set b=true
if GetLocalPlayer()==GetTriggerPlayer()then
call MultiboardDisplay(LQ[s],false)
call MultiboardDisplay(LQ[s2],true)
endif
set KQ[GetPlayerId(GetTriggerPlayer())]=LQ[s2]
endif
endloop
endif
endif
endfunction
function ILV takes nothing returns nothing
local integer i=0
local real hp=.0
local multiboarditem X5=null
local real D8
local real IMV
loop
exitwhen i>$B
if GetPlayerSlotState(Player(i))==PLAYER_SLOT_STATE_PLAYING then
set X5=MultiboardGetItem(LQ[i],3,1)
if GetUnitState(NS[i],UNIT_STATE_LIFE)>.405 then
set D8=GetUnitState(NS[i],UNIT_STATE_LIFE)
set IMV=GetUnitState(NS[i],UNIT_STATE_MAX_LIFE)
set hp=(D8/ IMV)*100.
if hp<=33.33 then
call MultiboardSetItemValue(X5,(("|c00FF0000"+I2S(R2I(hp)))+"%|r"))
elseif hp<=66.66 then
call MultiboardSetItemValue(X5,(("|c00FFFF00"+I2S(R2I(hp)))+"%|r"))
else
call MultiboardSetItemValue(X5,(("|c0033FF00"+I2S(R2I(hp)))+"%|r"))
endif
else
call MultiboardSetItemValue(X5,"|c00FF00000%|r")
call MultiboardReleaseItem(X5)
endif
endif
set i=i+1
endloop
set X5=null
endfunction
function CutBattleTag takes string text returns string 
    local integer len = StringLength(text)
    local integer i = 0

    loop 
        exitwhen i >= len or SubString(text, i, i+1) == "#"
        set i = i + 1
    endloop

    return SubString(text, 0, i)
endfunction
function IPV takes nothing returns nothing
local integer i=0
loop
exitwhen i==$C
set XS[i]=CutBattleTag(GetPlayerName(Player(i)))
set i=i+1
endloop
call DestroyTrigger(GetTriggeringTrigger())
endfunction
function IQV takes nothing returns boolean
return(IsUnitType(GetFilterUnit(),UNIT_TYPE_HERO) and GetUnitState(GetFilterUnit(),UNIT_STATE_LIFE)>.405)!=null
endfunction
function ISV takes nothing returns nothing
local group g=D1()
local unit u
local real x
local real y
call GroupEnumUnitsInRect(g,bj_mapInitialPlayableArea,Condition(function IQV))
loop
set u=FirstOfGroup(g)
exitwhen u==null
set x=GetUnitX(u)
set y=GetUnitY(u)
if(GetFloatGameState(GAME_STATE_TIME_OF_DAY)>=18. and GetFloatGameState(GAME_STATE_TIME_OF_DAY)<=24.)or(GetFloatGameState(GAME_STATE_TIME_OF_DAY)>=.0 and GetFloatGameState(GAME_STATE_TIME_OF_DAY)<6.)then
if IsTerrainPathable(x,y,PATHING_TYPE_FLOATABILITY)==false then
call SetUnitState(u,UNIT_STATE_LIFE,GetUnitState(u,UNIT_STATE_LIFE)+5.)
call SetUnitState(u,UNIT_STATE_MANA,GetUnitState(u,UNIT_STATE_MANA)+.1)
endif
elseif GetFloatGameState(GAME_STATE_TIME_OF_DAY)>=6. or GetFloatGameState(GAME_STATE_TIME_OF_DAY)<18. then
if IsTerrainPathable(x,y,PATHING_TYPE_FLOATABILITY) then
call SetUnitState(u,UNIT_STATE_LIFE,GetUnitState(u,UNIT_STATE_LIFE)+2.)
call SetUnitState(u,UNIT_STATE_MANA,GetUnitState(u,UNIT_STATE_MANA)+.15)
endif
endif
call GroupRemoveUnit(g,u)
endloop
call F1(g)
set g=null
endfunction
function ITV takes nothing returns boolean
return(GetHeroLevel(GetTriggerUnit())>=$A)
endfunction
function IUV takes nothing returns boolean
return(ITV())
endfunction
function IWV takes nothing returns boolean
return(GetUnitAbilityLevelSwapped('A01Y',GetTriggerUnit())==0)
endfunction
function IYV takes nothing returns boolean
return(GetUnitTypeId(GetTriggerUnit())=='E000')
endfunction
function IZV takes nothing returns boolean
return(GetUnitAbilityLevelSwapped('A00D',GetTriggerUnit())==0)and(GetUnitAbilityLevelSwapped('A01X',GetTriggerUnit())==0)
endfunction
function I_V takes nothing returns boolean
return(IZV())
endfunction
function I0V takes nothing returns boolean
return(GetUnitTypeId(GetTriggerUnit())=='E004')
endfunction
function I1V takes nothing returns boolean
return(GetUnitAbilityLevelSwapped('A01J',GetTriggerUnit())==0)
endfunction
function I2V takes nothing returns boolean
return(GetUnitTypeId(GetTriggerUnit())=='E006')
endfunction
function I3V takes nothing returns boolean
return(GetUnitAbilityLevelSwapped('A029',GetTriggerUnit())==0)
endfunction
function I4V takes nothing returns boolean
return(GetUnitTypeId(GetTriggerUnit())=='E008')
endfunction
function I5V takes nothing returns boolean
return(GetUnitAbilityLevelSwapped('A02C',GetTriggerUnit())==0)
endfunction
function I6V takes nothing returns boolean
return(GetUnitTypeId(GetTriggerUnit())=='E007')
endfunction
function I7V takes nothing returns boolean
return(GetUnitAbilityLevelSwapped('A02A',GetTriggerUnit())==0)
endfunction
function I8V takes nothing returns boolean
return(GetUnitTypeId(GetTriggerUnit())=='E00B')
endfunction
function I9V takes nothing returns boolean
return(GetUnitAbilityLevelSwapped('A020',GetTriggerUnit())==0)
endfunction
function AVV takes nothing returns boolean
return(GetUnitTypeId(GetTriggerUnit())=='E005')
endfunction
function AEV takes nothing returns nothing
if(IYV())then
if(IWV())then
call UnitAddAbility(GetTriggerUnit(),'A01Y')
endif
endif
if(I0V())then
if(I_V())then
call UnitAddAbility(GetTriggerUnit(),'A00D')
call UnitAddAbility(GetTriggerUnit(),'A01X')
call SetUnitAbilityLevelSwapped('A01X',GetTriggerUnit(),2)
call SetPlayerAbilityAvailableBJ(false,'A01X',GetOwningPlayer(GetTriggerUnit()))
endif
endif
if(I2V())then
if(I1V())then
call UnitAddAbility(GetTriggerUnit(),'A01J')
endif
endif
if(I4V())then
if(I3V())then
call UnitAddAbility(GetTriggerUnit(),'A029')
endif
endif
if(I6V())then
if(I5V())then
call UnitAddAbility(GetTriggerUnit(),'A02C')
endif
endif
if(I8V())then
if(I7V())then
call UnitAddAbility(GetTriggerUnit(),'A02A')
endif
endif
if(AVV())then
if(I9V())then
call UnitAddAbility(GetTriggerUnit(),'A020')
endif
endif
endfunction
function AOV takes integer i returns real
return 350.+(100.*i)+.5
endfunction
function ARV takes integer i returns real
return 1500.+(500.*i)
endfunction
function AIV takes nothing returns boolean
return GetSpellAbilityId()=='A006' or GetSpellAbilityId()=='A022'
endfunction
function AAV takes nothing returns nothing
local unit u=GetTriggerUnit()
local unit t=GetSpellTargetUnit()
local integer i=GetUnitAbilityLevel(u,GetSpellAbilityId())
local real cx=GetUnitX(u)
local real cy=GetUnitY(u)
local real tx
local real ty
local location l=GetSpellTargetLoc()
call SetUnitState(u,UNIT_STATE_LIFE,GetUnitState(u,UNIT_STATE_LIFE)+(100.+(i*100.)))
if t!=null then
set tx=GetUnitX(t)
set ty=GetUnitY(t)
else
set tx=GetLocationX(l)
set ty=GetLocationY(l)
endif
call U7('h002',u,i,cx,cy,tx,ty,.03,75.,33.,33.,.3,ARV(i),AOV(i),u,null)
set u=null
set t=null
call RemoveLocation(l)
set l=null
endfunction
function ANV takes integer i returns real
return 133.33+(66.66*i)+.5
endfunction
function ABV takes integer i returns real
return 333.33+(666.66*i)
endfunction
function ACV takes nothing returns nothing
local unit u=GetTriggerUnit()
local unit t=GetSpellTargetUnit()
local location l=GetSpellTargetLoc()
local integer i=GetUnitAbilityLevel(u,GetSpellAbilityId())
local real cx=GetUnitX(u)
local real cy=GetUnitY(u)
local real tx
local real ty
if t!=null then
set tx=GetUnitX(t)
set ty=GetUnitY(t)
else
set tx=GetLocationX(l)
set ty=GetLocationY(l)
endif
call U7('h00J',u,i,cx,cy,tx,ty,.03,60.,33.,33.,.3,ABV(i),ANV(i),u,null)
set u=null
set t=null
call RemoveLocation(l)
set l=null
endfunction
function ADV takes nothing returns boolean
return GetSpellAbilityId()=='A011' or GetSpellAbilityId()=='A017'
endfunction
function AFV takes nothing returns nothing
call CameraSetSmoothingFactor(5.)
set PX=1
loop
exitwhen PX>$C
call TriggerRegisterPlayerChatEvent(CR,Player(-1+(PX)),"-clear",false)
call TriggerRegisterPlayerChatEvent(DR,Player(-1+(PX)),"g2g",false)
call TriggerRegisterPlayerChatEvent(DR,Player(-1+(PX)),"gtg",false)
call TriggerRegisterPlayerChatEvent(DR,Player(-1+(PX)),"have to go",false)
call TriggerRegisterPlayerChatEvent(DR,Player(-1+(PX)),"bye",false)
call TriggerRegisterPlayerChatEvent(DR,Player(-1+(PX)),"cya",false)
set PX=PX+1
endloop
set QX=1
loop
exitwhen QX>$C
call SetCameraFieldForPlayer(Player(-1+(QX)),CAMERA_FIELD_TARGET_DISTANCE,2000.,1.)
set QX=QX+1
endloop
call O1()
call DestroyTrigger(GetTriggeringTrigger())
endfunction
function AHV takes nothing returns nothing
call TriggerRegisterDeathEvent(AR,GetEnumDestructable())
endfunction
function AJV takes nothing returns nothing
call EnumDestructablesInRectAll(GetWorldBounds(),function AHV)
endfunction
function ALV takes nothing returns nothing
local destructable AMV=GetDyingDestructable()
call TriggerSleepAction(150.)
call DestructableRestoreLife(AMV,GetDestructableMaxLife(AMV),true)
endfunction
function AQV takes nothing returns nothing
call DisplayTextToPlayer(GetTriggerPlayer(),.0,.0,ES[GetPlayerId(GetTriggerPlayer())]+XS[GetPlayerId(GetTriggerPlayer())]+"'s|r movespeed is |cffffcc00"+I2S(R2I(GetUnitMoveSpeed(NS[GetPlayerId(GetTriggerPlayer())])-1.))+"|r")
endfunction
function ASV takes nothing returns nothing
local real d
set d=I1(GetTriggerPlayer())
call DisplayTextToPlayer(GetTriggerPlayer(),.0,.0,"|cffffcc00Your Delay: |r"+R2S(d)+"|cffffcc00 milliseconds|r")
endfunction
function ATV takes nothing returns nothing
local real X6V
set X6V=S2R(SubString(GetEventPlayerChatString(),4,$A))
if X6V>.0 or X6V<=10. then
set WQ[GetPlayerId(GetTriggerPlayer())]=X6V
call DisplayTimedTextToPlayer(GetTriggerPlayer(),.0,.0,X6V,"|cffffcc00Text fades in "+R2S(X6V)+" seconds|r")
else
call DisplayTimedTextToPlayer(GetTriggerPlayer(),.0,.0,WQ[GetPlayerId(GetTriggerPlayer())],"|cffffcc00Time must be greater than 0 and less than or equal to 10|r")
endif
endfunction
function TT___Conditions takes nothing returns boolean
return SubString(GetEventPlayerChatString(),0,4)=="-tt "
endfunction
function AUV takes nothing returns boolean
local integer d=T3()
set WH[d]=WH[d]-1
if FR then
return true
endif
if WH[d]==60 then
if GetWidgetLife(IS[UH[d]])>.405 then
call DoNothing( )
endif
