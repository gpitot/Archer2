function ZW takes itemtype VY,integer EY returns nothing
local group g
set bj_stockPickedItemType=VY
set bj_stockPickedItemLevel=EY
set g=CreateGroup()
call GroupEnumUnitsOfType(g,"marketplace",PW)
call ForGroup(g,function UpdateEachStockBuildingEnum)
call DestroyGroup(g)
set g=null
endfunction
function XY takes nothing returns nothing
local integer pickedItemId
local itemtype OY
local integer RY=0
local integer IY=0
local integer EY

call msgTimer("XY Start")
set EY=1
loop
if(bj_stockAllowedPermanent[EY])then
set IY=IY+1
if(GetRandomInt(1,IY)==1)then
set OY=ITEM_TYPE_PERMANENT
set RY=EY
endif
endif
if(bj_stockAllowedCharged[EY])then
set IY=IY+1
if(GetRandomInt(1,IY)==1)then
set OY=ITEM_TYPE_CHARGED
set RY=EY
endif
endif
if(bj_stockAllowedArtifact[EY])then
set IY=IY+1
if(GetRandomInt(1,IY)==1)then
set OY=ITEM_TYPE_ARTIFACT
set RY=EY
endif
endif
set EY=EY+1
exitwhen EY>$A
endloop
if(IY==0)then
set OY=null
return
endif
call ZW(OY,RY)
set OY=null
call msgTimer("XY Finish")
endfunction
function AY takes nothing returns nothing
call XY()
call TimerStart(bj_stockUpdateTimer,bj_STOCK_RESTOCK_INTERVAL,true,function XY)
endfunction
function BY takes nothing returns boolean
return true
endfunction
