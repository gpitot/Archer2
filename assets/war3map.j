call UnitModifySkillPoints(GetTriggerUnit(),-1)
else
call UnitRemoveAbility(GetTriggerUnit(),'A011')
call UnitAddAbility(GetTriggerUnit(),'A011')
call SetUnitAbilityLevel(GetTriggerUnit(),'A011',b)
endif
endfunction
